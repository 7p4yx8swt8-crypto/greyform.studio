---
import { useTranslations, type Lang } from "../i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();
---

<footer>
  <div class="seal" aria-hidden="true">
    <svg viewBox="0 0 100 100">
      <defs>
        <path
          id="seal-circle"
          d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"
        ></path>
      </defs>
      <text>
        <textPath href="#seal-circle" startOffset="0">
          GREYFORM STUDIO · DIGITAL EXPERIENCES ·
        </textPath>
      </text>
    </svg>
    <span class="gf">GF</span>
  </div>

  <div class="col">
    <span>© {year} Studio Greyform</span>
    <span>{t("footer.tag")}</span>
  </div>

  <div class="col right">
    <a href={lang === "de" ? "/imprint" : "/en/imprint"}>{t("footer.imprint")}</a>
    <a href={lang === "de" ? "/privacy" : "/en/privacy"}>{t("footer.privacy")}</a>
  </div>
</footer>

<style>
  footer {
    padding: 48px var(--gutter) 32px;
    border-top: 1px solid rgba(13, 13, 13, 0.12);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 32px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .seal {
    width: 92px;
    height: 92px;
    border-radius: 50%;
    border: 1px solid rgba(13, 13, 13, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    font-size: 9px;
    letter-spacing: 0.22em;
    color: var(--fg);
    flex-shrink: 0;
  }
  .seal .gf {
    font-size: 18px;
    letter-spacing: 0.06em;
    font-weight: 500;
  }
  .seal svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .seal svg text {
    font-size: 6.6px;
    letter-spacing: 2.2px;
    fill: var(--fg);
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .col.right {
    align-items: flex-end;
    text-align: right;
  }
  .col a {
    transition: color 0.3s var(--ease);
  }
  .col a:hover {
    color: var(--fg);
  }

  @media (max-width: 720px) {
    footer {
      flex-direction: column;
      align-items: flex-start;
    }
    .col.right {
      align-items: flex-start;
      text-align: left;
    }
  }
</style>