---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="contact">
  <div class="wrap">
    <SectionHead
      num="05"
      eyebrow={t("contact.eyebrow")}
      title1={t("contact.heading1")}
      title2={t("contact.heading2")}
    />

    <div class="contact-grid">
      <p class="contact-body">{t("contact.body")}</p>

      <div class="contact-channels">
        <div class="channel">
          <span class="label">{t("contact.emailLabel")}</span>
          <a href="mailto:hello@greyform.studio">hello@greyform.studio</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--section-y);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(40px, 8vw, 100px);
    align-items: end;
  }
  .contact-body {
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.6;
    max-width: 46ch;
    color: #2a2a28;
  }
  .contact-channels {
    display: grid;
    gap: 22px;
    font-size: 13px;
  }
  .channel {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .channel .label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .channel a {
    font-size: 17px;
    letter-spacing: -0.005em;
    transition: color 0.3s var(--ease);
  }
  .channel a:hover {
    color: var(--color-stone);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
