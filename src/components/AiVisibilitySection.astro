---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";
export interface Props {
  lang?: Lang;
}
const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---
<section id="ai-visibility">
  <div class="wrap">
    <div class="ai-inner">
      <SectionHead
        num="07"
        eyebrow={t("aiVisibility.eyebrow")}
        title1={t("aiVisibility.title1")}
        title2={t("aiVisibility.title2")}
      />
      <div class="ai-body">
        <p class="ai-lead">{t("aiVisibility.p1")}</p>
        <p>{t("aiVisibility.p2")}</p>
        <p>{t("aiVisibility.p3")}</p>
        <div class="ai-pillars">
          <div class="pillar">
            <span class="pillar-label">{t("aiVisibility.pillar1Label")}</span>
            <span class="pillar-value">{t("aiVisibility.pillar1Value")}</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">{t("aiVisibility.pillar2Label")}</span>
            <span class="pillar-value">{t("aiVisibility.pillar2Value")}</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">{t("aiVisibility.pillar3Label")}</span>
            <span class="pillar-value">{t("aiVisibility.pillar3Value")}</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">{t("aiVisibility.pillar4Label")}</span>
            <span class="pillar-value">{t("aiVisibility.pillar4Value")}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  section {
    padding-block: var(--section-y);
    background: var(--color-ink, #0d0d0d);
    color: var(--color-paper, #f5f3ef);
  }
  .ai-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 8vw, 120px);
    align-items: start;
  }
  .ai-body {
    padding-top: clamp(16px, 3vw, 32px);
  }
  .ai-lead {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.5;
    margin-bottom: 20px;
    color: var(--color-paper, #f5f3ef);
  }
  p {
    font-size: clamp(13px, 1.2vw, 15px);
    line-height: 1.8;
    color: rgba(245, 243, 239, 0.6);
    margin-bottom: 16px;
  }
  .ai-pillars {
    margin-top: clamp(32px, 5vw, 56px);
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(245, 243, 239, 0.12);
  }
  .pillar {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-block: 18px;
    border-bottom: 1px solid rgba(245, 243, 239, 0.12);
  }
  .pillar-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 243, 239, 0.4);
  }
  .pillar-value {
    font-size: clamp(12px, 1.1vw, 14px);
    line-height: 1.5;
    color: var(--color-paper, #f5f3ef);
  }
  @media (max-width: 800px) {
    .ai-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
