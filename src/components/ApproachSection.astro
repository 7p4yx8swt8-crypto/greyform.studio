---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---

<section id="approach" class="approach">
  <div class="wrap">
    <SectionHead
      num="04"
      eyebrow={t("approach.eyebrow")}
      title1={t("approach.title1")}
      title2={t("approach.title2")}
      theme="dark"
    />

    <div class="approach-body-wrap">
      <div class="approach-body">
        <p>{t("approach.p1")}</p>
        <p>{t("approach.p2")}</p>
      </div>
    </div>

    <div class="pillars">
      <div class="pillar">
        <div class="label">{t("approach.pillar1Label")}</div>
        <div class="val">{t("approach.pillar1Value")}</div>
      </div>
      <div class="pillar">
        <div class="label">{t("approach.pillar2Label")}</div>
        <div class="val">{t("approach.pillar2Value")}</div>
      </div>
      <div class="pillar">
        <div class="label">{t("approach.pillar3Label")}</div>
        <div class="val">{t("approach.pillar3Value")}</div>
      </div>
      <div class="pillar">
        <div class="label">{t("approach.pillar4Label")}</div>
        <div class="val">{t("approach.pillar4Value")}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .approach {
    background: var(--color-black);
    color: var(--color-white);
    padding-block: var(--section-y);
  }

  .approach-body-wrap {
    display: flex;
    justify-content: flex-end;
  }
  .approach-body {
    max-width: 64ch;
  }
  .approach-body p {
    margin-bottom: 1.4em;
    color: rgba(245, 243, 239, 0.78);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.65;
  }
  .approach-body p:last-child {
    margin-bottom: 0;
  }

  .pillars {
    margin-top: clamp(60px, 10vw, 120px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    border-top: 1px solid rgba(245, 243, 239, 0.18);
    padding-top: 40px;
  }
  .pillar .label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(245, 243, 239, 0.6);
    margin-bottom: 14px;
  }
  .pillar .val {
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.005em;
  }

  @media (max-width: 900px) {
    .approach-body-wrap {
      justify-content: flex-start;
    }
    .approach-body {
      max-width: 100%;
    }
    .pillars {
      grid-template-columns: 1fr 1fr;
      gap: 24px 32px;
    }
  }
</style>
