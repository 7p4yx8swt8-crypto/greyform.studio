---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---

<section id="studio">
  <div class="wrap">
    <SectionHead
      num="01"
      eyebrow={t("studio.eyebrow")}
      title1={t("studio.title1")}
      title2={t("studio.title2")}
    />

    <div class="studio-body">
      <p>{t("studio.p1")}</p>
      <p>{t("studio.p2")}</p>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--section-y);
  }
  .studio-body {
    max-width: 64ch;
    margin-left: auto;
  }
  .studio-body p {
    margin-bottom: 1.4em;
    color: #2a2a28;
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.65;
  }
  .studio-body p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .studio-body {
      max-width: 100%;
      margin-left: 0;
    }
  }
</style>
