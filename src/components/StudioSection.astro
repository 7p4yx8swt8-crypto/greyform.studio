---
import { useTranslations, type Lang } from "../i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---

<section id="studio">
  <div class="wrap">
    <div class="eyebrow">
      <span class="num">01</span><span class="line"></span><span>{t("studio.eyebrow")}</span>
    </div>

    <div class="studio-grid">
      <p class="studio-lead">
        <span>{t("studio.lead1")}</span> <em>{t("studio.lead2")}</em>
      </p>

      <div class="studio-body">
        <p>{t("studio.p1")}</p>
        <p>{t("studio.p2")}</p>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--section-y);
  }
  .studio-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 8vw, 120px);
    align-items: start;
  }
  .studio-lead {
    font-size: clamp(22px, 2.4vw, 34px);
    line-height: 1.3;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .studio-lead em {
    font-style: italic;
    color: var(--color-stone);
    font-weight: 300;
  }
  .studio-body p {
    margin-bottom: 1.2em;
    max-width: 56ch;
    color: #2a2a28;
  }
  .studio-body p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 900px) {
    .studio-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
