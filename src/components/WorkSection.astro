---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";

export interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
const t = useTranslations(lang);

// Localized labels for work items
const labels = {
  de: {
    jinaCat: "Editorial · Brand Site",
    greyCat: "Studio · Eigene Plattform",
  },
  en: {
    jinaCat: "Editorial · Brand Site",
    greyCat: "Studio · Own Platform",
  },
}[lang];

// Localized URLs
const jinaUrl = lang === "de" ? "/work/jina-kim" : "/en/work/jina-kim";
const greyUrl = lang === "de" ? "/work/the-grey" : "/en/work/the-grey";
---

<section id="work">
  <div class="wrap">
    <SectionHead
      num="02"
      eyebrow={t("work.eyebrow")}
      title1={t("work.title1")}
      title2={t("work.title2")}
    />

    <div class="work-grid">
      <article class="work-item">
        <a href={jinaUrl} class="work-link">
          <div class="work-media">
            <img
              src="/work/jina-kim/cover.jpg"
              alt="Ji-Na Kim — Editorial Brand Site"
              loading="lazy"
            />
          </div>
        </a>
        <div class="work-meta">
          <span class="title">Ji-Na Kim</span>
          <span class="cat">{labels.jinaCat}</span>
        </div>
        <a class="work-arrow" href={jinaUrl}>
          <span>{t("work.cta")}</span> <span class="arr">→</span>
        </a>
      </article>

      <article class="work-item">
        <a href={greyUrl} class="work-link">
          <div class="work-media dark">
            <img
              src="/work/thegrey-berlin/00-cover.jpg"
              alt="thegrey.berlin — Brand Identity & Website"
              loading="lazy"
              class="img-bottom"
            />
          </div>
        </a>
        <div class="work-meta">
          <span class="title">The Grey</span>
          <span class="cat">{labels.greyCat}</span>
        </div>
        <a class="work-arrow" href={greyUrl}>
          <span>{t("work.cta")}</span> <span class="arr">→</span>
        </a>
      </article>

      <article class="work-item upcoming">
        <div class="work-media sand">
  <img
    src={lang === "de" ? "/work/next-project/next-project-de.svg" : "/work/next-project/next-project-en.svg"}
    alt={lang === "de" ? "Nächstes Projekt — In Kürze" : "Next Project — Coming Soon"}
    loading="lazy"
  />
</div>
        <div class="work-meta">
          <span class="title">{t("work.tbd")}</span>
          <span class="cat">{t("work.soon")}</span>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--section-y);
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 56px) clamp(24px, 5vw, 64px);
  }
  .work-item:nth-child(2) {
    margin-top: clamp(40px, 12vw, 160px);
  }
  .work-item:nth-child(3) {
    margin-top: clamp(-60px, -6vw, -20px);
  }

  .work-link {
    display: block;
  }
  .work-media {
    aspect-ratio: 4 / 5;
    background: var(--color-sand);
    overflow: hidden;
    position: relative;
    transition: opacity 0.4s var(--ease);
  }
  .work-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.6s var(--ease);
  }
  .work-media img.img-bottom {
    object-position: center 75%;
  }
  .work-link:hover .work-media img {
    filter: grayscale(0%);
  }
  .work-link:hover .work-media {
    opacity: 0.85;
  }
  .work-media.dark {
    background: #111;
    aspect-ratio: 5 / 6;
  }
  .work-media.sand {
    background: #ece8e2;
  }
  .work-media .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(13, 13, 13, 0.18);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .work-media.dark .placeholder {
    color: rgba(245, 243, 239, 0.18);
  }

  .work-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 18px;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .work-meta .title {
    font-weight: 500;
  }
  .work-meta .cat {
    color: var(--muted);
    font-size: 11px;
  }

  .work-arrow {
    margin-top: 14px;
    font-size: 13px;
    letter-spacing: 0.04em;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: gap 0.4s var(--ease);
  }
  .work-arrow:hover {
    gap: 18px;
  }

  .work-item.upcoming {
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .work-grid {
      grid-template-columns: 1fr;
    }
    .work-item:nth-child(2),
    .work-item:nth-child(3) {
      margin-top: 0;
    }
  }
</style>
