---
import { useTranslations, type Lang } from "../i18n/ui";
import SectionHead from "./SectionHead.astro";
export interface Props {
  lang?: Lang;
}
const { lang = "de" } = Astro.props;
const t = useTranslations(lang);
---
<section id="industries">
  <div class="wrap">
    <SectionHead
      num="03"
      eyebrow={t("industries.eyebrow")}
      title1={t("industries.title1")}
      title2={t("industries.title2")}
    />
    <div class="industries-grid">
      <article class="industry-item">
        <h3>{t("industries.i1Heading")}</h3>
        <p>{t("industries.i1Body")}</p>
      </article>
      <article class="industry-item">
        <h3>{t("industries.i2Heading")}</h3>
        <p>{t("industries.i2Body")}</p>
      </article>
      <article class="industry-item">
        <h3>{t("industries.i3Heading")}</h3>
        <p>{t("industries.i3Body")}</p>
      </article>
      <article class="industry-item">
        <h3>{t("industries.i4Heading")}</h3>
        <p>{t("industries.i4Body")}</p>
      </article>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--section-y);
  }
  .industries-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--color-border, #e0ddd8);
    border: 1px solid var(--color-border, #e0ddd8);
  }
  .industry-item {
    background: var(--color-bg, #f5f3ef);
    padding: clamp(32px, 5vw, 56px);
  }
  .industry-item h3 {
    font-size: clamp(14px, 1.5vw, 16px);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .industry-item p {
    font-size: clamp(13px, 1.2vw, 15px);
    line-height: 1.7;
    color: var(--muted);
    max-width: 36ch;
  }
  @media (max-width: 700px) {
    .industries-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
