---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "de";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Website Design für Möbelmarken",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet editoriale Websites und flexible digitale Systeme für Möbelmarken, Möbelhersteller, Lichtmarken und Interior-Produktmarken.",
  "areaServed": "Worldwide",
  "serviceType": "Website Design",
  "audience": {
    "@type": "Audience",
    "audienceType": "Möbelmarken, Möbelhersteller, Lichtmarken, Interior-Produktmarken"
  }
};

const faqs = [
  {
    q: "Sind Sie auf Websites für Möbelmarken spezialisiert?",
    a: "Ja. Greyform arbeitet mit Möbelmarken, Möbelherstellern, Lichtmarken und Interior-Produktmarken. Wir verstehen die spezifischen Anforderungen der Kategorie — Produktpräsentation, Kollektionsstruktur, Markenerzählung — und gestalten Websites, die all das leisten."
  },
  {
    q: "Wie lange dauert ein Möbelmarken-Website-Projekt?",
    a: "Ein fokussiertes Projekt dauert in der Regel drei bis sechs Wochen von Briefing bis Launch. Der Zeitrahmen hängt vom Umfang der Inhalte, der Anzahl der Produktlinien und davon ab, ob ein Content-System integriert wird."
  },
  {
    q: "Können wir die Website nach dem Launch selbst pflegen?",
    a: "Ja — und das ist ein zentrales Ziel unserer Arbeit. Wir entwickeln flexible Content-Systeme, mit denen Ihr Team Kollektionen aktualisieren, Produkte hinzufügen und Inhalte pflegen kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein."
  },
  {
    q: "Arbeiten Sie auch mit Möbelmarken außerhalb Deutschlands?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Marken in ganz Europa zusammengearbeitet und sind offen für Projekte weltweit."
  },
  {
    q: "Können Sie bei der SEO für unsere Möbelmarken-Website helfen?",
    a: "Ja. SEO ist von Anfang an Teil jedes Projekts — semantische Struktur, Metadaten, Performance und Content-Architektur werden von Beginn an berücksichtigt. Wir strukturieren Inhalte auch so, dass sie von KI-Systemen wie ChatGPT und Googles AI Overviews klar verstanden werden."
  }
];
---

<BaseLayout
  title="Website Design für Möbelmarken — Greyform Studio Berlin"
  description="Greyform gestaltet editoriale Websites und digitale Markensysteme für Möbelmarken, Hersteller und Interior-Produktmarken. Studio in Berlin, international tätig."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Website Design · Möbelmarken</span>
      </div>
      <h1>
        <span>Website Design</span><br />
        <span>für Möbel-</span><br />
        <em>marken.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform gestaltet editoriale Websites und flexible digitale Systeme für Möbelmarken, Hersteller und Interior-Produktmarken — präzise umgesetzt, nach dem Launch eigenständig pflegbar.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. WARUM MÖBELMARKEN ANDERE WEBSITES BRAUCHEN -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Herausforderung</span>
        </div>
        <h2>
          Warum Möbelmarken<br />
          <em>andere Websites brauchen.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Möbelmarken-Website ist kein Produktkatalog. Sie ist ein Markenerlebnis — und die meisten Websites in dieser Kategorie liefern keines.</p>
          <p>Möbelmarken operieren in einer Kategorie, in der das physische Produkt aspirativ, haptisch und tief mit einem Lebensgefühl verknüpft ist. Die Website muss dieses Gewicht tragen. Sie muss Kollektionen mit editorialer Präzision präsentieren, Handwerk und Materialien klar kommunizieren und eine Markengeschichte erzählen, die einem Käufer einen Grund gibt, sich für diese Marke zu entscheiden.</p>
          <p>Generische Website-Builder und Template-basierte Agenturen verstehen das nicht. Sie produzieren Sites, die wie jede andere Möbelwebsite aussehen — Produktgrids, Slider-Karussells, Stockfotografie. Das Ergebnis ist ein digitaler Auftritt, der aktiv das bereits geleistete Markeninvestment untergräbt.</p>
          <p>Greyform arbeitet anders. Wir entwickeln Websites für Möbelmarken, die als editoriale Plattformen funktionieren — ruhig, präzise, markengeführt — und die nach dem Launch von Ihrem eigenen Team gepflegt und erweitert werden können.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Wochen von Briefing bis Launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Nach dem Launch eigenständig pflegbar</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual als Standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Möbelmarken-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Template-Ästhetik</h3>
          <p>Generische Themes und Drag-and-Drop-Builder erzeugen Sites, die von Mitbewerbern nicht zu unterscheiden sind. Das visuelle System kommuniziert nichts über die Marke.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Produkt zuerst, Marke zuletzt</h3>
          <p>Die meisten Möbelwebsites führen mit Produktgrids und Preisen. Markengeschichte, Materialphilosophie und Designprozess — die Dinge, die einen Premiumpreis rechtfertigen — fehlen oder sind kaum auffindbar.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>Kein Content-System</h3>
          <p>Websites, die ohne Entwickler nicht aktualisiert werden können, veralten innerhalb von Monaten. Neue Kollektionen werden nicht gelauncht. Presseberichte werden nicht ergänzt. Die Site hört auf, als Marketing-Werkzeug zu funktionieren.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Schwache SEO-Architektur</h3>
          <p>Möbelmarken investieren in hochwertige Fotografie, vernachlässigen aber die semantische Struktur, Ladegeschwindigkeit und Metadaten, die bestimmen, ob diese Investition über die Suche irgendjemanden erreicht.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Nicht für internationale Zielgruppen gebaut</h3>
          <p>Einsprachige Websites ohne hreflang-Struktur, lokalisierte Inhalte und internationale SEO lassen erhebliche Märkte unerschlossen — besonders für Marken, die Handelskunden in ganz Europa ansprechen möchten.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Langsame Performance</h3>
          <p>Bildlastige Möbelwebsites laden häufig langsam, was sowohl die Nutzererfahrung als auch die Suchmaschinen-Rankings schädigt. Performance sollte von Anfang an als Design-Constraint verstanden werden, nicht als Nachgedanke.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Editoriales Design.<br />
          <em>Präzise Umsetzung.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Jedes Greyform-Projekt beginnt mit der Marke, nicht mit dem Template.</p>
          <p>Wir lesen die visuelle Sprache, die eine Möbelmarke bereits besitzt — in ihren Produkten, ihrer Fotografie, ihren Printmaterialien — und gestalten ein digitales System, das diese Sprache fortsetzt, anstatt sie in etwas Generisches zu übersetzen.</p>
          <p>Das Ergebnis ist eine Website, die sich wie eine Erweiterung der Marke liest. Typografie, Weißraum, Bildbehandlung, Seitenstruktur und Navigation werden als Teil eines kohärenten Ganzen betrachtet. Nicht aus Komponenten zusammengesetzt, sondern von Grund auf um das gestaltet, was diese spezifische Marke kommunizieren muss.</p>
          <p>Wir arbeiten mit wenigen Projekten parallel. Das bedeutet klare Verantwortung, kurze Kommunikationswege und ein Maß an Aufmerksamkeit, das größere Agenturen mit größeren Kundenlisten nicht bieten können. Von Briefing bis Launch in Wochen, nicht Monaten — ohne Qualität für Geschwindigkeit zu opfern.</p>
          <p>Referenzprojekte: <a href="/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Ansatz</span>
            <span class="pillar-value">Markengeführt, nicht templategeführt</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Tempo</span>
            <span class="pillar-value">Wochen, nicht Monate</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Ästhetik</span>
            <span class="pillar-value">Editorial · Architektonisch</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Sprachen</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. FLEXIBLE CONTENT-SYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Content-Systeme</span>
        </div>
        <h2>
          Websites, die Ihr Team<br />
          <em>eigenständig pflegen kann.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Möbelmarken-Website ist nie fertig. Kollektionen ändern sich. Neue Produkte werden gelauncht. Presseberichte kommen hinzu. Messeauftritte müssen angekündigt werden.</p>
          <p>Deshalb entwickeln wir flexible Content-Systeme — keine statischen Websites. Jedes Greyform-Projekt ist so strukturiert, dass Ihr Team Kollektionen aktualisieren, Produkte hinzufügen, Journal-Beiträge veröffentlichen und Inhalte nach dem Launch pflegen kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein.</p>
          <p>Das System ist auf die redaktionellen Bedürfnisse einer Möbelmarke ausgelegt: strukturierte Produkteinträge, Kollektionsübersichten, Material- und Spezifikationsseiten, Presse- und Journal-Bereiche. Jeder Bereich kann unabhängig, im Browser, von jedem Teammitglied mit grundlegenden Computerkenntnissen aktualisiert werden.</p>
          <p>Wir dokumentieren das System und übergeben es am Ende jedes Projekts klar und vollständig. Es gehört Ihnen.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Kollektion- und Produktverwaltung</li>
            <li>Journal- und Pressebereich</li>
            <li>Team- und About-Seiten</li>
            <li>Projekt- und Case-Study-Einträge</li>
            <li>Kein Entwickler für Content-Updates erforderlich</li>
            <li>Vollständige Dokumentation bei Übergabe</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/work/the-grey" class="work-link">
            <div class="work-media">
              <img
                src="/work/thegrey-berlin/00-cover.jpg"
                alt="thegrey.berlin — Brand Identity & Website für ein Berliner Teppich-Label"
                loading="lazy"
                class="img-bottom"
              />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey">
            <span>Projekt ansehen</span> <span class="arr">→</span>
          </a>
        </article>
        <article class="work-item">
          <a href="/work/jina-kim" class="work-link">
            <div class="work-media">
              <img
                src="/work/jina-kim/cover.jpg"
                alt="Ji-Na Kim — Editorial Brand Site"
                loading="lazy"
              />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim">
            <span>Projekt ansehen</span> <span class="arr">→</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- 7. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>Wir beginnen mit einem fokussierten Briefing — Ihre Marke, Ihre Zielgruppe, Ihre Ziele. Keine langen Discovery-Phasen oder teure Strategiedokumente. Ein klares Gespräch, ein gemeinsames Verständnis, ein definierter Umfang.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>Wir gestalten das vollständige visuelle System — Typografie, Layout, Farbe, Bildbehandlung, Komponentenbibliothek — bevor wir eine Zeile Code schreiben. Sie reviewen, reagieren und wir verfeinern. In der Regel zwei Überarbeitungsrunden bis zur Freigabe.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Entwicklung</h3>
            <p>Wir bauen die Site mit derselben Sorgfalt wie das Design. Performance, semantisches HTML, SEO-Struktur und Content-System-Architektur werden als Kernleistungen behandelt, nicht als optionale Extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Übergabe</h3>
            <p>Wir übernehmen den technischen Launch — Domain-Konfiguration, Hosting-Setup, Analytics und Sitemap-Einreichung. Wir dokumentieren das Content-System klar und übergeben alles, damit Ihr Team von Tag eins eigenständig arbeiten kann.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.a
          }
        }))
      })} />
    </div>
  </section>

  <!-- 9. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Projekt starten</span>
        </div>
        <h2>
          Bereit für etwas<br />
          <em>Durchdachtes?</em>
        </h2>
        <p>Erzählen Sie uns von Ihrer Möbelmarke und was Sie brauchen. Wir antworten innerhalb von zwei Werktagen mit einer ehrlichen Einschätzung und einem klaren nächsten Schritt.</p>
        <a href="mailto:hello@greyform.studio" class="cta-btn">Gespräch beginnen →</a>
        <p class="cta-sub">Oder <a href="/#contact">nutzen Sie das Kontaktformular</a> auf unserer Hauptseite.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(60px, 10vw, 120px);
    padding-top: clamp(120px, 14vw, 180px);
  }
  .hero-tag {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: clamp(24px, 4vw, 48px);
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .hero-tag .dot {
    width: 6px;
    height: 6px;
    background: var(--color-black);
    border-radius: 50%;
  }
  .hero h1 {
    font-size: clamp(44px, 9.2vw, 168px);
    line-height: 0.92;
    font-weight: 400;
    letter-spacing: -0.025em;
    max-width: 14ch;
  }
  .hero h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-stone);
  }
  .hero-foot {
    margin-top: clamp(24px, 4vw, 48px);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 40px;
    flex-wrap: wrap;
  }
  .hero-sub {
    max-width: 46ch;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.55;
  }
  .hero-meta {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
  }
  .hero-meta .row { display: flex; gap: 28px; }
  section { padding-block: var(--section-y); }
  .section-head { margin-bottom: clamp(48px, 8vw, 96px); }
  .eyebrow-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(16px, 2vw, 24px);
  }
  .num { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); }
  .dash { width: 32px; height: 1px; background: var(--muted); opacity: 0.4; }
  .eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
  h2 { font-size: clamp(32px, 5vw, 72px); font-weight: 400; line-height: 1.05; letter-spacing: -0.02em; }
  h2 em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 8vw, 120px); align-items: start; }
  .col-text p { font-size: clamp(13px, 1.2vw, 15px); line-height: 1.8; color: var(--muted); margin-bottom: 20px; }
  .col-text p.lead { font-size: clamp(16px, 1.6vw, 20px); line-height: 1.5; color: var(--color-black); margin-bottom: 24px; }
  .col-text a { color: var(--color-black); text-decoration: underline; text-underline-offset: 3px; }
  .stat-block { display: flex; flex-direction: column; gap: 32px; padding-top: clamp(16px, 3vw, 48px); border-top: 1px solid var(--color-border, #e0ddd8); }
  .stat-item { display: flex; flex-direction: column; gap: 6px; }
  .stat-value { font-size: clamp(28px, 3vw, 44px); font-weight: 400; letter-spacing: -0.02em; line-height: 1; }
  .stat-label { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .section-problems { background: var(--color-ink, #0d0d0d); color: var(--color-paper, #f5f3ef); }
  .section-problems h2 em { color: rgba(245,243,239,0.4); }
  .section-problems .eyebrow, .section-problems .num { color: rgba(245,243,239,0.4); }
  .section-problems .dash { background: rgba(245,243,239,0.2); }
  .problems-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: rgba(245,243,239,0.1); border: 1px solid rgba(245,243,239,0.1); }
  .problem-item { background: var(--color-ink, #0d0d0d); padding: clamp(28px, 4vw, 48px); }
  .problem-num { display: block; font-size: 11px; letter-spacing: 0.2em; color: rgba(245,243,239,0.3); margin-bottom: 16px; }
