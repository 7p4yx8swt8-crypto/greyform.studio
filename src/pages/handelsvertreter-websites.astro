---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "de";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digitale Auftritte für selbständige Handelsagenturen",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet professionelle Websites, Markenpräsentationen und digitale Systeme für selbständige Handelsagenturen aus der Möbel-, Interior- und Designbranche.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Markenpräsentation", "Content-Systeme", "SEO"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Selbständige Handelsagentur, Handelsagenturen, Vertriebsprofis in der Möbel- und Designbranche"
  },
  "knowsAbout": ["Handelsagentur-Websites", "Markenpräsentation", "Mehrmandantenstruktur", "B2B-Kommunikation", "Designbranche", "Vertretungsportfolio"]
};

const faqs = [
  {
    q: "Für welche Handelsagenturen arbeitet Greyform?",
    a: "Wir arbeiten mit selbständigen Handelsagentur/Innen, die hochwertige Produkte vertreten — aus den Bereichen Möbel, Interior, Licht, Textil, Sanitär, Boden oder verwandten Designbranchen. Sowohl Einzelpersonen als auch kleine Vertreterbüros."
  },
  {
    q: "Ich vertrete mehrere Marken — wie bildet die Website das ab?",
    a: "Das ist der Kern unserer Arbeit für Handelsagentur. Wir entwickeln Strukturen, die mehrere Marken klar geordnet präsentieren — mit eigenem Raum für jede Linie, ohne dass die Seite unübersichtlich wirkt. Die Besucher verstehen sofort, womit Sie arbeiten."
  },
  {
    q: "Brauche ich als Handelsagentur wirklich eine eigene Website?",
    a: "Ja — und zwar eine, die Sie als eigenständigen Profi positioniert. Einkäufer und Architekten, die eine neue Zusammenarbeit prüfen, suchen Sie zuerst online. Eine fehlende oder unprofessionelle Präsenz kostet Glaubwürdigkeit, noch bevor das erste Gespräch stattfindet."
  },
  {
    q: "Können wir die Website nach dem Launch selbst pflegen?",
    a: "Das ist ein zentrales Ziel. Wir entwickeln Content-Systeme, die eigenständig bedienbar sind — neue Marken hinzufügen, Produktlinien aktualisieren, Kontaktdaten ändern. Ohne technisches Vorwissen, ohne Entwickler."
  },
  {
    q: "Wie läuft ein Projekt bei Greyform ab?",
    a: "Wir beginnen mit einem Gespräch über Ihr Vertretungsportfolio, Ihre Zielgruppe und Ihre Ziele. Dann entwickeln wir Konzept, Design und Struktur — bevor eine Zeile Code geschrieben wird. Die Umsetzung folgt mit klaren Meilensteinen. Kein endloser Abstimmungsprozess."
  },
  {
    q: "Arbeiten Sie auch mit Handelsagenturen außerhalb Deutschlands?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Unternehmen in ganz Europa zusammengearbeitet und sind offen für Projekte weltweit."
  }
];
---

<BaseLayout
  title="Websites für selbständige Handelsagenturen — Greyform Studio Berlin"
  description="Greyform gestaltet professionelle Websites und digitale Auftritte für selbständige Handelsagentur/Innen aus der Möbel-, Interior- und Designbranche. Mehr Glaubwürdigkeit, mehr Anfragen."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digitale Auftritte · Handelsagentur</span>
      </div>
      <h1>
        <span>Digitale Auftritte für</span><br />
        <em>selbständige Handelsagentur.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform gestaltet professionelle Websites, Markenpräsentationen und digitale Systeme für Handelsagenturen aus der Möbel-, Interior- und Designbranche — damit Sie online so überzeugend auftreten wie persönlich.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. WARUM HANDELSAGENTUREN ANDERE WEBSITES BRAUCHEN -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Ausgangslage</span>
        </div>
        <h2>
          Warum Handelsagenturen<br />
          <em>andere Websites brauchen.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Handelsagentur-Website ist keine digitale Visitenkarte. Sie ist ein Werkzeug, das Vertrauen schafft — bevor das erste Gespräch stattfindet.</p>
          <p>Handelsagentur operieren in einer Kategorie, in der persönliche Beziehungen zählen — aber der erste Eindruck heute online entsteht. Einkäufer, Innenarchitekten und Projektverantwortliche recherchieren Ihre Vertretungsagentur, bevor sie anrufen. Was sie finden, entscheidet darüber, ob sie anrufen.</p>
          <p>Die meisten Handelsagentur haben keine Website — oder eine, die ihrer tatsächlichen Qualität nicht entspricht. Eine LinkedIn-Seite, ein veralteter Auftritt, ein PDF-Portfolio: Das ist kein digitaler Auftritt. Das ist eine verpasste Chance.</p>
          <p>Greyform entwickelt digitale Systeme für Handelsagentur, die als professionelle Plattform funktionieren — mehrere Marken klar präsentiert, Zielgruppen direkt angesprochen, eigenständig pflegbar nach dem Launch.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–5</span>
              <span class="stat-label">Wochen von Briefing bis Launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Nach dem Launch eigenständig pflegbar</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual als Standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        Der erste Eindruck<br />
        entsteht heute online.<br />
        <em>Bevor jemand anruft.</em>
      </h2>
    </div>
  </section>

  <!-- 3. WARUM GREYFORM -->
  <section class="section-credibility">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Branchenverständnis</span>
        </div>
        <h2>
          Warum Greyform Handelsagentur<br />
          <em>von innen versteht.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Greyform nähert sich Handelsagenturn nicht als externe Agentur, die eine neue Kategorie kennenlernt. Das Studio bringt direkte Erfahrung aus der Möbel- und Einrichtungsbranche mit.</p>
          <p>Wir verstehen, wie Handelsagentur arbeiten — Vertretungsgebiete, Markenbeziehungen, Showrooms, Messen, Einkaufszyklen, B2B-Kommunikation. Wir verstehen den Unterschied zwischen einer Produktlinie und einem Vollsortiment, zwischen einem Fachhandelspartner und einem Objektkunden.</p>
          <p>Wir verstehen, dass eine Handelsagentur-Website mehrere Zielgruppen bedienen muss: den Einkäufer, der einen neuen Lieferanten bewertet, den Innenarchitekten, der eine Marke spezifiziert, den Hersteller, der einen neuen Vertreter sucht. Jede dieser Zielgruppen braucht etwas anderes — ein gut strukturiertes System kann alle bedienen.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Mehrmandantenstruktur</span>
              <span class="cred-text">Mehrere Marken gleichzeitig klar und geordnet präsentieren — ohne Durcheinander, mit eigenem Raum für jede Linie</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Vertretungsgebiet</span>
              <span class="cred-text">Klare Kommunikation von Region, Vertriebskanälen und Spezialisierungen — damit die richtigen Kontakte Sie finden</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">B2B-Kommunikation</span>
              <span class="cred-text">Sprache und Struktur für Einkäufer, Architekten und Projektverantwortliche — nicht für den Endkonsumenten</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Messen & Showrooms</span>
              <span class="cred-text">Digitale Verlängerung von Messeauftritten, Showroom-Terminen und persönlichen Präsentationen</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Handelsagentur-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Keine Präsenz</h3>
          <p>Viele Handelsagentur haben überhaupt keine eigene Website. LinkedIn ist kein Ersatz — es fehlt die Tiefe, die Struktur und die Professionalität, die Entscheider erwarten.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Marken nicht sichtbar</h3>
          <p>Wer starke Marken vertritt, sollte das zeigen. Eine einfache Liste mit Logos reicht nicht. Produktlinien, Kollektionen, Markenwelten brauchen Raum und Kontext.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>Keine Zielgruppensprache</h3>
          <p>Handelsagentur-Websites sprechen oft niemanden direkt an. Einkäufer, Architekten und Planer haben unterschiedliche Bedürfnisse — eine gute Seite adressiert sie klar.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Online unsichtbar</h3>
          <p>Wenn jemand nach einem Vertreter für eine bestimmte Marke oder Produktkategorie sucht, erscheinen die meisten Handelsagentur nicht. Fehlende SEO-Struktur kostet qualifizierte Anfragen.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Nicht pflegbar</h3>
          <p>Neue Marke im Portfolio, neue Kollektion, neues Vertretungsgebiet — wenn jede Änderung einen Entwickler braucht, veraltet die Seite schnell und verliert ihren Wert.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Schlechte Performance</h3>
          <p>Langsame, mobile-unoptimierte Seiten schaden dem Eindruck und dem Ranking. Technische Qualität ist kein Luxus — sie ist Grundvoraussetzung.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Professionell positioniert.<br />
          <em>Eigenständig pflegbar.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Jedes Greyform-Projekt für Handelsagentur beginnt mit einer Frage: Wie treten Sie auf — und wie sollten Sie auftreten?</p>
          <p>Wir lesen Ihr Portfolio, Ihre Marken, Ihre Zielgruppen — und entwickeln ein digitales System, das diese Realität klar und überzeugend abbildet. Keine Templates, kein Copy-Paste. Eine Seite, die zu Ihrer Vertretungsstruktur passt.</p>
          <p>Das Ergebnis ist ein Auftritt, der professionell wirkt ohne aufgeblasen zu sein. Klar strukturiert, schnell ladend, auf allen Geräten überzeugend. Und nach dem Launch vollständig in Ihrer Hand — ohne Abhängigkeit von externen Dienstleistern für inhaltliche Updates.</p>
          <p>Wir arbeiten mit wenigen Projekten parallel. Das bedeutet klare Verantwortung, kurze Kommunikationswege und ein Maß an Aufmerksamkeit, das größere Agenturen nicht bieten können.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Ansatz</span>
            <span class="pillar-value">Strukturgeführt, nicht templategeführt</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Tempo</span>
            <span class="pillar-value">Wochen, nicht Monate</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Zielgruppe</span>
            <span class="pillar-value">B2B · Einkauf · Architektur · Planung</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Sprachen</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WAS WIR ENTWICKELN -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Leistungen</span>
        </div>
        <h2>
          Was wir für Handelsagentur<br />
          <em>entwickeln.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Ein Handelsagentur-Portfolio verändert sich laufend. Neue Marken kommen hinzu. Kollektionen wechseln. Vertretungsgebiete ändern sich.</p>
          <p>Deshalb entwickeln wir flexible Content-Systeme — keine statischen Websites. Jedes Greyform-Projekt ist so strukturiert, dass Sie Ihr Markenportfolio eigenständig aktualisieren, neue Produktlinien ergänzen und Inhalte nach dem Launch pflegen können — ohne für jede Änderung auf externe Hilfe angewiesen zu sein.</p>
          <p>Das System ist auf die spezifischen Bedürfnisse von Handelsagenturn ausgelegt: strukturierte Markenprofile, Produktübersichten, Kontakt- und Anfragebereiche, optionale Katalog- und Download-Strukturen. Alles eigenständig bedienbar, vollständig dokumentiert.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Marken- und Produktlinienpräsentation</li>
            <li>Vertretungsgebiet und Spezialisierungen</li>
            <li>Kontakt- und Anfragestruktur</li>
            <li>Optionale Katalog- und Download-Bereiche</li>
            <li>Kein Entwickler für Content-Updates erforderlich</li>
            <li>Vollständige Dokumentation bei Übergabe</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Sichtbar für Menschen.<br />
        <em>Verständlich für KI.</em>
      </h2>
    </div>
  </section>

  <!-- 7. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Für Suchmaschinen gebaut.<br />
          <em>Bereit für KI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Das Suchverhalten ändert sich. Einkäufer, Architekten und Planer nutzen zunehmend KI-Systeme, um Lieferanten zu recherchieren und Handelsagentur zu finden — bevor sie persönlichen Kontakt aufnehmen.</p>
          <p>Wenn jemand ChatGPT fragt „Wer vertritt Marke X in Bayern?" oder Google nach einem Handelsagentur für Objektmöbel durchsucht — entscheidet die Struktur Ihrer Website darüber, ob Ihr Name fällt. Oder der eines Wettbewerbers.</p>
          <p>Greyform strukturiert Inhalte, Markenprofile und Leistungsseiten so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, wen Sie vertreten, in welchem Gebiet Sie tätig sind und warum Sie die richtige Wahl sind. Das ist kein technischer Nachgedanke — es ist ein grundlegender Teil der Gestaltung.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantische Struktur</span>
            <span class="pillar-value">Sauberes HTML, korrekte Überschriftenhierarchie, Entity-Klarheit</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Strukturierte Daten</span>
            <span class="pillar-value">Schema.org-Markup für Leistungen, FAQs und Unternehmensidentität</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Branchenspezifische Keywords</span>
            <span class="pillar-value">Markennamen, Produktkategorien, Regionen — so wie Ihre Zielgruppe sucht</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">KI-Lesbarkeit</span>
            <span class="pillar-value">Inhalte strukturiert für ChatGPT, Gemini, Perplexity und Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>Wir beginnen mit einem fokussierten Gespräch — Ihr Portfolio, Ihre Zielgruppen, Ihre Ziele. Keine langen Discovery-Phasen oder teure Strategiedokumente. Ein klares Gespräch, ein gemeinsames Verständnis, ein definierter Umfang.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>Wir gestalten das vollständige visuelle System — Typografie, Layout, Farbe, Struktur — bevor wir eine Zeile Code schreiben. Sie reviewen, reagieren und wir verfeinern. In der Regel zwei Überarbeitungsrunden bis zur Freigabe.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Entwicklung</h3>
            <p>Wir bauen die Site mit derselben Sorgfalt wie das Design. Performance, semantisches HTML, SEO-Struktur und Content-System-Architektur werden als Kernleistungen behandelt, nicht als optionale Extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Übergabe</h3>
            <p>Wir übernehmen den technischen Launch — Domain-Konfiguration, Hosting-Setup, Analytics und Sitemap-Einreichung. Wir dokumentieren das Content-System klar und übergeben alles, damit Sie von Tag eins eigenständig arbeiten können.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. VERWANDTE BRANCHEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <a href="/furniture-brand-websites" class="related-item related-link-item">
          <span class="related-label">Möbelmarken</span>
          <p>Editoriale Websites und digitale Markensysteme für Möbelhersteller und Designmarken.</p>
        </a>
        <a href="/interior-brand-websites" class="related-item related-link-item">
          <span class="related-label">Interior-Marken</span>
          <p>Websites und Content-Systeme für Interior-, Licht-, Textil- und Wohnmarken.</p>
        </a>
        <a href="/architecture-studio-websites" class="related-item related-link-item">
          <span class="related-label">Architekturbüros</span>
          <p>Digitale Plattformen für Projektportfolios und Büropräsenzen.</p>
        </a>
        <a href="/lifestyle-brand-websites" class="related-item related-link-item">
          <span class="related-label">Lifestyle-Marken</span>
          <p>Premium-Digitalauftritte für designorientierte Konsumentenmarken.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 10. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.a
          }
        }))
      })} />
    </div>
  </section>

  <!-- 11. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">Projekt starten</span>
        </div>
        <h2>
          Lassen Sie uns über<br />
          <em>Ihr Projekt sprechen.</em>
        </h2>
