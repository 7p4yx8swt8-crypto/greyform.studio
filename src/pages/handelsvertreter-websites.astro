---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "Für welche Handelsvertreter arbeitet Greyform?",
    a: "Wir arbeiten mit selbständigen Handelsvertreter/Innen, die hochwertige Produkte vertreten — aus den Bereichen Möbel, Interior, Licht, Textil, Sanitär, Boden oder verwandten Designbranchen. Sowohl Einzelpersonen als auch kleine Vertreterbüros."
  },
  {
    q: "Ich vertrete mehrere Marken — wie bildet die Website das ab?",
    a: "Das ist der Kern unserer Arbeit für Handelsvertreter. Wir entwickeln Strukturen, die mehrere Marken klar geordnet präsentieren — mit eigenem Raum für jede Linie, ohne dass die Seite unübersichtlich wirkt. Die Besucher verstehen sofort, womit Sie arbeiten."
  },
  {
    q: "Brauche ich als Handelsvertreter wirklich eine eigene Website?",
    a: "Ja — und zwar eine, die Sie als eigenständigen Profi positioniert. Einkäufer und Architekten, die eine neue Zusammenarbeit prüfen, suchen Sie zuerst online. Eine fehlende oder unprofessionelle Präsenz kostet Glaubwürdigkeit, noch bevor das erste Gespräch stattfindet."
  },
  {
    q: "Können wir die Website nach dem Launch selbst pflegen?",
    a: "Das ist ein zentrales Ziel. Wir entwickeln Content-Systeme, die eigenständig bedienbar sind — neue Marken hinzufügen, Produktlinien aktualisieren, Kontaktdaten ändern. Ohne technisches Vorwissen, ohne Entwickler."
  },
  {
    q: "Wie läuft ein Projekt bei Greyform ab?",
    a: "Wir beginnen mit einem Gespräch über Ihr Vertretungsportfolio, Ihre Zielgruppe und Ihre Ziele. Dann entwickeln wir Konzept, Design und Struktur — bevor eine Zeile Code geschrieben wird. Die Umsetzung folgt mit klaren Meilensteinen. Kein endloser Abstimmungsprozess."
  },
  {
    q: "Arbeitet Greyform auch mit kleinen Budgets?",
    a: "Wir sind kein Massendienstleister, aber auch keine Großagentur. Unsere Projekte sind auf selbständige Unternehmer zugeschnitten — fokussiert, klar im Scope, ohne versteckte Kosten. Sprechen Sie uns an: Wir finden gemeinsam den richtigen Rahmen."
  }
];
---

<BaseLayout
  title="Websites für selbständige Handelsvertreter — Greyform Studio Berlin"
  description="Greyform entwickelt professionelle Websites und digitale Auftritte für selbständige Handelsvertreter/Innen aus der Möbel-, Interior- und Designbranche. Mehr Glaubwürdigkeit, mehr Anfragen."
  lang="de"
>

  <!-- 01. HERO -->
  <section class="section-hero">
    <div class="wrap">
      <div class="eyebrow-row">
        <span class="num">01</span>
        <span class="dash"></span>
        <span class="eyebrow">Handelsvertreter</span>
      </div>
      <h1>
        Digitale Auftritte für<br />
        <em>selbständige Handelsvertreter.</em>
      </h1>
      <p class="hero-sub">
        Greyform entwickelt professionelle Websites, Markenpräsentationen und digitale Systeme für Handelsvertreter/Innen aus der Möbel-, Interior- und Designbranche — damit Sie online so überzeugend auftreten wie persönlich.
      </p>
      <a href="#kontakt" class="btn">Projekt besprechen →</a>
    </div>
  </section>

  <!-- 02. WARUM HANDELSVERTRETER ANDERE WEBSITES BRAUCHEN -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Ausgangslage</span>
        </div>
        <h2>
          Warum Handelsvertreter<br />
          <em>andere Websites brauchen.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <h3>Keine professionelle Präsenz</h3>
          <p>Viele Handelsvertreter sind über LinkedIn oder eine veraltete Firmenwebsite erreichbar — aber nicht wirklich präsent. Potentielle Kunden und Partner machen sich ein erstes Bild online. Wer dort nicht überzeugt, verliert Glaubwürdigkeit noch vor dem ersten Gespräch.</p>
        </div>
        <div class="problem-item">
          <h3>Marken werden nicht richtig sichtbar</h3>
          <p>Sie vertreten starke Marken — aber Ihre Website zeigt das nicht. Produktlinien, Kataloge, Kollektionen: all das braucht eine klare, geordnete digitale Bühne. Nicht eine Auflistung, sondern eine Präsentation.</p>
        </div>
        <div class="problem-item">
          <h3>Zu wenig qualifizierte Anfragen</h3>
          <p>Neue Kontakte entstehen oft nur durch persönliche Netzwerke oder Messen. Eine professionelle Website arbeitet im Hintergrund weiter — und bringt Anfragen von Einkäufern, Architekten und Planern, die aktiv suchen.</p>
        </div>
        <div class="problem-item">
          <h3>Online nicht auffindbar</h3>
          <p>Wenn jemand nach einem Handelsvertreter für eine bestimmte Marke oder Produktkategorie sucht — erscheinen Sie? Google und KI-Systeme bevorzugen strukturierte, klare Inhalte. Wer diese Grundlage nicht hat, ist unsichtbar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 03. WARUM GREYFORM -->
  <section class="section-credibility">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Branchenverständnis</span>
        </div>
        <h2>
          Warum Greyform Handelsvertreter<br />
          <em>von innen versteht.</em>
        </h2>
      </div>
      <div class="credibility-content">
        <p class="credibility-lead">Greyform kommt nicht von außen. Die Wurzeln des Studios liegen in der Möbel-, Interior- und Designwelt. Wir wissen, wie die Branche funktioniert: Showrooms, Messen, Vertretungsgebiete, Markenbeziehungen, Einkaufszyklen.</p>
        <div class="credibility-points">
          <div class="credibility-point">
            <span class="point-label">Mehrmandantenstruktur</span>
            <p>Wir entwickeln Seiten, die mehrere Marken gleichzeitig klar und geordnet präsentieren — ohne Unübersichtlichkeit, ohne Durcheinander.</p>
          </div>
          <div class="credibility-point">
            <span class="point-label">Zielgruppe verstanden</span>
            <p>Ihre Besucher sind Einkäufer, Innenarchitekten, Planer und Projektverantwortliche. Wir wissen, wie man sie anspricht und überzeugt.</p>
          </div>
          <div class="credibility-point">
            <span class="point-label">Kein Agentur-Overhead</span>
            <p>Greyform ist ein kleines, fokussiertes Studio. Sie arbeiten direkt mit den Menschen, die Ihre Website gestalten und bauen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 04. WAS WIR ENTWICKELN -->
  <section class="section-services-detail">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Leistungen</span>
        </div>
        <h2>
          Was wir für Handelsvertreter<br />
          <em>entwickeln.</em>
        </h2>
      </div>
      <div class="services-detail-grid">
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Professioneller Webauftritt</h3>
            <p>Ihre digitale Visitenkarte — klar, überzeugend, auf Ihren Markt zugeschnitten. Mit allem, was Einkäufer und Partner erwarten: Vertretungsgebiet, Markenportfolio, Kontakt.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Marken- und Produktpräsentation</h3>
            <p>Jede von Ihnen vertretene Marke bekommt den Raum, den sie verdient. Strukturiert, mit Bildwelt, Produktinformationen und weiterführenden Links — als Grundlage für Akquise-Gespräche.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Pflegbares Content-System</h3>
            <p>Neue Marke im Portfolio? Neue Kollektion? Sie aktualisieren die Website selbst — ohne Entwickler, ohne Wartezeiten. Das System ist auf Selbständige ausgelegt.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Suchmaschinenoptimierung</h3>
            <p>Strukturierte Seiten, die bei Google und in KI-Suchsystemen gefunden werden — wenn Einkäufer nach Vertretern für bestimmte Marken oder Produktkategorien suchen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 05. TYPISCHES PROJEKT -->
  <section class="section-scope">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Projektrahmen</span>
        </div>
        <h2>
          Was ein typisches Projekt<br />
          <em>umfasst.</em>
        </h2>
      </div>
      <div class="scope-list">
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Strategiegespräch zu Portfolio, Zielgruppe und Positionierung</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Konzept und Seitenstruktur auf Basis Ihrer Vertretungen</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Visuelles Design — Typografie, Farbsystem, Bildsprache</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Entwicklung mit performanter, suchmaschinenoptimierter Technik</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Einbindung Ihrer Marken, Kataloge und Produktinformationen</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Pflegbares System für eigenständige Updates</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Launch, Domain-Setup, Analytics, Übergabedokumentation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 06. FÜR SUCHMASCHINEN UND KI -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Sichtbarkeit</span>
        </div>
        <h2>
          Für Suchmaschinen gebaut.<br />
          <em>Bereit für KI.</em>
        </h2>
      </div>
      <div class="ai-content">
        <p class="ai-lead">Wenn ein Einkäufer ChatGPT fragt „Wer vertritt Marke X in Bayern?" oder Google nach einem Handelsvertreter für Objektmöbel durchsucht — entscheidet die Struktur Ihrer Website darüber, ob Ihr Name fällt. Oder der eines Wettbewerbers.</p>
        <div class="ai-points">
          <div class="ai-point">
            <h3>Semantische Struktur</h3>
            <p>Saubere HTML-Semantik und strukturierte Inhalte, die Suchmaschinen und KI-Systeme korrekt auslesen und einordnen können.</p>
          </div>
          <div class="ai-point">
            <h3>Branchenspezifische Keywords</h3>
            <p>Inhalte, die die Begriffe verwenden, nach denen Ihre Zielgruppe tatsächlich sucht — Markennamen, Produktkategorien, Regionen.</p>
          </div>
          <div class="ai-point">
            <h3>Schnell und technisch sauber</h3>
            <p>Ladezeiten, Core Web Vitals, mobile Optimierung — alles als Standard, nicht als Aufpreis.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 07. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Fragen</span>
        </div>
        <h2>
          Fragen, die wir<br />
          <em>oft hören.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item, i) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 08. RELATED -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Weitere Branchen</span>
        </div>
        <h2>
          Andere Branchen,<br />
          <em>für die wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <a href="/furniture-brand-websites" class="related-item related-link">
          <span class="related-label">Möbelmarken</span>
          <p>Editoriale Websites und digitale Markensysteme für Möbelhersteller und Designmarken.</p>
        </a>
        <a href="/interior-brand-websites" class="related-item related-link">
          <span class="related-label">Interior-Marken</span>
          <p>Websites und Content-Systeme für Interior-, Licht-, Textil- und Wohnmarken.</p>
        </a>
        <a href="/architecture-studio-websites" class="related-item related-link">
          <span class="related-label">Architekturbüros</span>
          <p>Digitale Plattformen für Projektportfolios und Büropräsenzen.</p>
        </a>
        <a href="/lifestyle-brand-websites" class="related-item related-link">
          <span class="related-label">Lifestyle-Marken</span>
          <p>Premium-Digitalauftritte für designorientierte Konsumentenmarken.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 09. CTA / KONTAKT -->
  <section class="section-contact" id="kontakt">
    <div class="wrap">
      <div class="eyebrow-row">
        <span class="num">09</span>
        <span class="dash"></span>
        <span class="eyebrow">Kontakt</span>
      </div>
      <h2>
        Ob neues Portfolio,<br />
        Neupositionierung oder erster<br />
        <em>professioneller Webauftritt —</em><br />
        wir hören zu.
      </h2>
      <a href="mailto:hello@greyform.studio" class="btn">hello@greyform.studio →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared layout helpers ─────────────────────────────── */
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); }
  .section-head { margin-bottom: var(--space-xl); }
  .eyebrow-row { display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-md); }
  .num { font-variant-numeric: tabular-nums; opacity: .4; font-size: .85rem; }
  .dash { flex: 0 0 2rem; height: 1px; background: currentColor; opacity: .2; }
  .eyebrow { font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; opacity: .5; }
  .btn { display: inline-block; margin-top: var(--space-lg); padding: .75rem 1.75rem; border: 1px solid currentColor; font-size: .9rem; letter-spacing: .06em; text-decoration: none; transition: opacity .2s; }
  .btn:hover { opacity: .6; }

  /* ── Hero ──────────────────────────────────────────────── */
  .section-hero { padding: calc(var(--space-xl) * 2.5) 0 calc(var(--space-xl) * 2); }
  .section-hero h1 { font-size: clamp(2.4rem, 5vw, 4.5rem); line-height: 1.05; margin-bottom: var(--space-lg); }
  .hero-sub { max-width: 56ch; font-size: 1.05rem; line-height: 1.65; opacity: .75; }

  /* ── Problems ──────────────────────────────────────────── */
  .section-problems { padding: calc(var(--space-xl) * 2) 0; }
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-xl) var(--space-lg); margin-top: var(--space-xl); }
  .problem-item h3 { font-size: 1rem; margin-bottom: var(--space-sm); }
  .problem-item p { font-size: .9rem; line-height: 1.7; opacity: .7; }

  /* ── Credibility ───────────────────────────────────────── */
  .section-credibility { padding: calc(var(--space-xl) * 2) 0; }
  .credibility-lead { font-size: 1.1rem; line-height: 1.7; max-width: 64ch; margin-bottom: var(--space-xl); opacity: .85; }
  .credibility-points { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); }
  .credibility-point { border-top: 1px solid currentColor; padding-top: var(--space-md); opacity: .8; }
  .point-label { display: block; font-size: .8rem; letter-spacing: .08em; text-transform: uppercase; margin-bottom: var(--space-sm); opacity: .55; }
  .credibility-point p { font-size: .9rem; line-height: 1.65; }

  /* ── Services detail ───────────────────────────────────── */
  .section-services-detail { padding: calc(var(--space-xl) * 2) 0; }
  .services-detail-grid { display: grid; gap: var(--space-lg); }
  .service-detail-item { display: grid; grid-template-columns: 2rem 1fr; gap: var(--space-md); padding: var(--space-lg) 0; border-top: 1px solid currentColor; border-top-color: color-mix(in srgb, currentColor 15%, transparent); }
  .service-num { opacity: .3; padding-top: .15rem; }
  .service-detail-item h3 { font-size: 1rem; margin-bottom: var(--space-sm); }
  .service-detail-item p { font-size: .9rem; line-height: 1.7; opacity: .7; }

  /* ── Scope ─────────────────────────────────────────────── */
  .section-scope { padding: calc(var(--space-xl) * 2) 0; }
  .scope-list { display: grid; gap: var(--space-sm); margin-top: var(--space-xl); max-width: 680px; }
  .scope-item { display: flex; align-items: baseline; gap: var(--space-md); padding: var(--space-sm) 0; border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent); font-size: .95rem; line-height: 1.6; }
  .scope-check { opacity: .4; flex-shrink: 0; }

  /* ── AI ────────────────────────────────────────────────── */
  .section-ai { padding: calc(var(--space-xl) * 2) 0; }
  .ai-lead { font-size: 1.05rem; line-height: 1.7; max-width: 64ch; margin-bottom: var(--space-xl); opacity: .85; }
  .ai-points { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); }
  .ai-point { border-top: 1px solid currentColor; padding-top: var(--space-md); }
  .ai-point h3 { font-size: .95rem; margin-bottom: var(--space-sm); }
  .ai-point p { font-size: .9rem; line-height: 1.65; opacity: .7; }

  /* ── FAQ ───────────────────────────────────────────────── */
  .section-faq { padding: calc(var(--space-xl) * 2) 0; }
  .faq-list { max-width: 760px; }
  .faq-item { border-top: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .faq-item:last-child { border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .faq-q { display: flex; justify-content: space-between; align-items: center; padding: var(--space-md) 0; cursor: pointer; font-size: .95rem; list-style: none; gap: var(--space-md); }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-icon { flex-shrink: 0; opacity: .4; transition: transform .2s; }
  details[open] .faq-icon { transform: rotate(45deg); }
  .faq-a { padding-bottom: var(--space-md); font-size: .9rem; line-height: 1.75; opacity: .7; max-width: 64ch; }

  /* ── Related ───────────────────────────────────────────── */
  .section-related { padding: calc(var(--space-xl) * 2) 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .related-item { padding: var(--space-lg); border: 1px solid color-mix(in srgb, currentColor 12%, transparent); }
  .related-link { text-decoration: none; color: inherit; transition: border-color .2s; }
  .related-link:hover { border-color: currentColor; }
  .related-label { display: block; font-size: .85rem; letter-spacing: .08em; text-transform: uppercase; margin-bottom: var(--space-sm); }
  .related-item p { font-size: .875rem; line-height: 1.65; opacity: .65; margin: 0; }

  /* ── Contact ───────────────────────────────────────────── */
  .section-contact { padding: calc(var(--space-xl) * 3) 0; }
  .section-contact h2 { font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.1; margin-top: var(--space-lg); }

  @media (max-width: 640px) {
    .problems-grid, .credibility-points, .ai-points { grid-template-columns: 1fr; }
    .service-detail-item { grid-template-columns: 1fr; }
    .service-num { display: none; }
  }
</style>
