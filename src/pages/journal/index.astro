---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "de";
const entries = await getCollection("journal", ({ data }) => data.lang === "de");
const sorted = entries.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Journal — Greyform Studio Berlin"
  description="Gedanken, Perspektiven und Einblicke zu digitalem Design, Markenauftritten und der Zukunft des Webs — vom Studio Greyform."
  lang={lang}
>
  <header class="journal-hero">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Journal · Greyform Studio</span>
      </div>
      <h1>
        Gedanken<br />
        <em>aus dem Studio.</em>
      </h1>
    </div>
  </header>

  <section class="journal-list">
    <div class="wrap">
      {sorted.length === 0 ? (
        <p class="journal-empty">Erste Beiträge erscheinen in Kürze.</p>
      ) : (
        <div class="entries">
          {sorted.map((entry) => (
            <article class="entry">
              <a href={`/journal/${entry.id.replace("-de", "")}`} class="entry-link">
                <div class="entry-meta">
                  <span class="entry-date">{new Date(entry.data.date).toLocaleDateString("de-DE", { year: "numeric", month: "long", day: "numeric" })}</span>
                  {entry.data.tags && entry.data.tags.map((tag: string) => (
                    <span class="entry-tag">{tag}</span>
                  ))}
                </div>
                <h2 class="entry-title">{entry.data.title}</h2>
                <p class="entry-desc">{entry.data.description}</p>
                <span class="entry-cta">Weiterlesen →</span>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .journal-hero {
    padding-top: clamp(120px, 14vw, 180px);
    padding-bottom: clamp(60px, 8vw, 100px);
  }
  .hero-tag {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: clamp(24px, 4vw, 48px);
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .hero-tag .dot {
    width: 6px;
    height: 6px;
    background: var(--color-black);
    border-radius: 50%;
  }
  h1 {
    font-size: clamp(44px, 7vw, 120px);
    line-height: 0.95;
    font-weight: 400;
    letter-spacing: -0.025em;
  }
  h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--color-stone);
  }
.journal-list {
    padding-top: clamp(40px, 5vw, 64px);
    padding-bottom: var(--section-y);
    border-top: 0.5px solid rgba(13,13,13,0.12);
  }
  .journal-empty {
    font-size: 15px;
    color: var(--muted);
  }
  .entries {
    display: flex;
    flex-direction: column;
  }
  .entry {
    border-bottom: 0.5px solid rgba(13,13,13,0.12);
  }
  .entry-link {
    display: block;
    padding-block: clamp(32px, 5vw, 56px);
    transition: opacity 0.3s var(--ease);
  }
  .entry-link:hover { opacity: 0.65; }
  .entry-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 16px;
  }
  .entry-date {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .entry-tag {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border: 0.5px solid rgba(13,13,13,0.2);
    padding: 2px 8px;
  }
  h2.entry-title {
    font-size: clamp(22px, 3vw, 40px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 16px;
  }
  .entry-desc {
    font-size: clamp(14px, 1.3vw, 16px);
    line-height: 1.65;
    color: var(--muted);
    max-width: 58ch;
    margin-bottom: 20px;
  }
  .entry-cta {
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-black);
  }
</style>
