---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "de";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digitale Auftritte für Interior-Marken",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet editoriale Websites und digitale Systeme für Interior-Marken, Lichtmarken, Textilmarken und Home-Brands. Studio in Berlin, international tätig.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Editorial Design", "Content-Systeme", "Digitale Markenstrategie"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Interior-Marken, Lichtmarken, Textilmarken, Home-Brands, Lifestyle-Labels"
  },
  "knowsAbout": ["Interior-Brand-Websites", "Editoriale Bildsprache", "Lookbook-Systeme", "Lifestyle-Kommunikation", "Home-Brand-Positionierung"]
};

const faqs = [
  {
    q: "Was unterscheidet eine Interior-Marken-Website von einer Möbelmarken-Website?",
    a: "Eine Möbelmarken-Website ist produktgetrieben — Kollektionen, Spezifikationen, Händlernetzwerke. Eine Interior-Marken-Website ist stimmungsgetrieben. Sie muss ein Lebensgefühl kommunizieren, nicht ein Produkt spezifizieren. Der Fokus liegt auf Atmosphäre, editorialer Bildsprache und dem kuratorischen Anspruch der Marke — nicht auf technischen Datenblättern."
  },
  {
    q: "Für welche Interior-Marken arbeitet Greyform?",
    a: "Wir arbeiten mit Lichtmarken, Textilmarken, Home-Accessoire-Labels, Raumausstattungsmarken und kuratorischen Interior-Brands. Gemeinsam ist ihnen ein klarer ästhetischer Standpunkt und der Wunsch nach einem digitalen Auftritt, der diesem Standpunkt gerecht wird."
  },
  {
    q: "Wie lange dauert ein Projekt?",
    a: "Ein fokussiertes Projekt dauert in der Regel drei bis sechs Wochen von Briefing bis Launch. Der Zeitrahmen hängt vom Umfang der Inhalte und davon ab, ob ein vollständiges Content-System oder ein Lookbook-Bereich integriert wird."
  },
  {
    q: "Können wir die Website nach dem Launch selbst pflegen?",
    a: "Ja — und das ist ein zentrales Ziel. Wir entwickeln flexible Content-Systeme, mit denen Ihr Team Kollektionen, Lookbooks und Inhalte eigenständig aktualisieren kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein."
  },
  {
    q: "Arbeiten Sie auch international?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Marken in ganz Europa zusammengearbeitet und sind offen für Projekte weltweit."
  },
  {
    q: "Können Sie bei SEO und KI-Sichtbarkeit helfen?",
    a: "Ja. Semantische Struktur, strukturierte Daten und inhaltliche Tiefe sind von Anfang an Teil jedes Projekts. Wir strukturieren Inhalte so, dass sie von KI-Systemen wie ChatGPT, Gemini und Google AI Overviews klar verstanden werden — die zunehmend genutzt werden, um Interior-Marken zu entdecken."
  }
];
---

<BaseLayout
  title="Digitale Auftritte für Interior-Marken — Greyform Studio Berlin"
  description="Greyform gestaltet editoriale Websites und digitale Systeme für Interior-Marken, Lichtmarken, Textilmarken und Home-Brands. Studio in Berlin, international tätig."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digitale Auftritte · Interior-Marken</span>
      </div>
      <h1>
        <span>Digitale Auftritte</span><br />
        <em>für Interior-Marken.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform gestaltet editoriale Websites und digitale Systeme für Interior-Marken, Lichtmarken, Textilmarken und Home-Brands — atmosphärisch, präzise, eigenständig pflegbar.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. STIMMUNG STATT SPEZIFIKATION -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Der Unterschied</span>
        </div>
        <h2>
          Stimmung statt<br />
          <em>Spezifikation.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Interior-Marken-Website funktioniert anders als eine Möbelmarken-Website. Nicht schlechter — anders.</p>
          <p>Möbelmarken sind produktgetrieben. Kollektionen, Varianten, Spezifikationen, Händlernetzwerke. Die Website muss Produkte erklären, vergleichbar machen, qualifizieren.</p>
          <p>Interior-Marken sind stimmungsgetrieben. Ein Lichtlabel, eine Textilmarke, ein kuratorisches Home-Brand — diese Marken verkaufen kein einzelnes Produkt, sie verkaufen eine Haltung. Ein Lebensgefühl. Eine Art zu wohnen und zu leben.</p>
          <p>Die Website einer Interior-Marke muss diese Haltung sofort spürbar machen — bevor jemand ein Produkt anklickt. Sie muss atmosphärisch sein, ohne unscharf zu sein. Editorial, ohne unzugänglich zu sein. Und sie muss ein Content-System haben, das die Marke kontinuierlich weiterentwickeln kann — mit Lookbooks, Kollektionsgeschichten, Materialerzählungen und kuratorischen Einblicken.</p>
          <p>Das ist eine andere Gestaltungsaufgabe. Wir verstehen den Unterschied.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Wochen von Briefing bis Launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Nach dem Launch eigenständig pflegbar</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual als Standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        Eine Interior-Marke verkauft<br />
        kein Produkt.<br />
        <em>Sie verkauft eine Haltung.</em>
      </h2>
    </div>
  </section>

  <!-- 3. WAS INTERIOR-MARKEN BRAUCHEN -->
  <section class="section-needs">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Was Interior-Marken brauchen</span>
        </div>
        <h2>
          Atmosphäre die trägt.<br />
          <em>Inhalte die wachsen.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Die digitale Präsenz einer Interior-Marke hat andere Anforderungen als die einer Produktmarke.</p>
          <p>Es geht nicht primär um Produktgrids und Filterfunktionen. Es geht um die Fähigkeit, eine Bildwelt zu etablieren — und kontinuierlich weiterzuerzählen. Neue Kollektionen als editoriale Geschichten. Materialien als Narrative. Räume als Referenzen. Das Studio hinter der Marke als Stimme.</p>
          <p>Greyform entwickelt digitale Systeme, die genau das ermöglichen: eine atmosphärische Grundhaltung die konstant bleibt, und ein Content-System das Raum für Entwicklung lässt. Kein statischer Auftritt — eine lebendige editoriale Plattform.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Atmosphäre & Bildsprache</span>
              <span class="cred-text">Visuelle Systeme die ein Lebensgefühl kommunizieren — konsistent über alle Seiten und Formate</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Lookbook-Systeme</span>
              <span class="cred-text">Saisonale und permanente Lookbooks als editoriale Erlebnisse — nicht als Produktkataloge</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Materialerzählungen</span>
              <span class="cred-text">Eigene Seiten für Materialien, Oberflächen, Herkunft und Handwerk — als Teil der Markengeschichte</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Kuratorische Stimme</span>
              <span class="cred-text">Journal-Systeme für Kollektionsgeschichten, Inspirationsquellen, Einblicke und Thought Leadership</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Interior-Marken-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Zu viel Shop, zu wenig Marke</h3>
          <p>Interior-Marken die ihre Website wie einen E-Commerce-Katalog aufbauen, verlieren das Wichtigste: die Atmosphäre. Produkte brauchen Kontext. Ohne ihn sind sie austauschbar.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Schöne Bilder, keine Erzählung</h3>
          <p>Viele Interior-Websites haben hervorragende Fotografie — aber keine Struktur die diese Bilder in eine Geschichte verwandelt. Das Ergebnis: Inspiration ohne Orientierung.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>Kein Content-System</h3>
          <p>Lookbooks die nicht aktualisiert werden. Kollektionen die online unsichtbar bleiben. Interior-Marken brauchen ein System das mit der Marke atmet — nicht eine statische Seite.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Template-Ästhetik</h3>
          <p>Interior-Marken mit ausgeprägter visueller Identität deserialieren diese Identität auf generischen Themes. Das digitale System muss die Marke fortsetzten — nicht übersetzen.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Keine internationale Reichweite</h3>
          <p>Interior-Marken mit internationalem Anspruch — aber einsprachigen Websites ohne hreflang-Struktur. Erhebliche Märkte bleiben unerschlossen.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Unsichtbar für KI</h3>
          <p>Marken die wunderschöne Bildwelten haben, aber keine strukturierten Inhalte. KI-Systeme können sie nicht verstehen — und empfehlen sie nicht.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Editoriales Design.<br />
          <em>Lebendige Plattform.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Jedes Greyform-Projekt beginnt mit der Marke, nicht mit dem Template.</p>
          <p>Bei Interior-Marken bedeutet das: wir lesen die Bildwelt, den Ton, die kuratorische Haltung — und gestalten ein digitales System, das diese Haltung fortsetzt. Nicht illustriert. Fortsetzt.</p>
          <p>Das Ergebnis ist eine Website die sich wie ein natürlicher Ausdruck der Marke anfühlt. Typografie, Weißraum, Bildbehandlung, Seitenrhythmus — alles als Teil eines kohärenten Ganzen. Und ein Content-System dahinter, das Ihr Team befähigt, die Marke kontinuierlich weiterzuerzählen.</p>
          <p class="internal-links">Referenzprojekte: <a href="/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Ansatz</span>
            <span class="pillar-value">Markengeführt, nicht templategeführt</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Tempo</span>
            <span class="pillar-value">Wochen, nicht Monate</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Ästhetik</span>
            <span class="pillar-value">Editorial · Atmosphärisch</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Sprachen</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONTENT-SYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Content-Systeme</span>
        </div>
        <h2>
          Eine Plattform die<br />
          <em>mit der Marke atmet.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Interior-Marken-Website ist nie fertig. Neue Kollektionen kommen. Lookbooks wechseln. Materialien werden ergänzt. Events angekündigt.</p>
          <p>Deshalb entwickeln wir flexible Content-Systeme — keine statischen Websites. Jedes Greyform-Projekt ist so strukturiert, dass Ihr Team Kollektionen aktualisieren, Lookbooks veröffentlichen, Journal-Beiträge schreiben und Inhalte pflegen kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein.</p>
          <p>Das System ist auf die redaktionellen Bedürfnisse einer Interior-Marke ausgelegt. Lookbook-Seiten. Kollektionsübersichten. Material- und Herkunftsseiten. Journal- und Pressebereich. Alles eigenständig, alles im Browser.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Lookbook- und Kollektionsverwaltung</li>
            <li>Journal- und Pressebereich</li>
            <li>Material- und Herkunftsseiten</li>
            <li>Team- und About-Seiten</li>
            <li>Kein Entwickler für Content-Updates erforderlich</li>
            <li>Vollständige Dokumentation bei Übergabe</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/work/the-grey" class="work-link">
            <div class="work-media">
              <img src="/work/thegrey-berlin/00-cover.jpg" alt="thegrey.berlin — Brand Identity & Website für ein Berliner Interior-Label" loading="lazy" class="img-bottom" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey"><span>Projekt ansehen</span> <span class="arr">→</span></a>
        </article>
        <article class="work-item">
          <a href="/work/jina-kim" class="work-link">
            <div class="work-media">
              <img src="/work/jina-kim/cover.jpg" alt="Ji-Na Kim — Editorial Brand Site" loading="lazy" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim"><span>Projekt ansehen</span> <span class="arr">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Sichtbar für Menschen.<br />
        <em>Verständlich für KI.</em>
      </h2>
    </div>
  </section>

  <!-- 8. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Für Suchmaschinen gebaut.<br />
          <em>Bereit für KI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Interior-Marken werden heute nicht nur über Instagram entdeckt. Sie werden recherchiert — von Architekten, Innenarchitekten, Redakteuren und Einkäufern.</p>
          <p>Zunehmend nutzen Fachleute KI-Systeme um Kategorien zu recherchieren, Marken zu vergleichen und Inspiration zu finden. Eine Interior-Marke die nicht klar für maschinenlesbare Inhalte strukturiert ist, ist für diese Systeme unsichtbar — unabhängig davon, wie stark ihre visuelle Identität ist.</p>
          <p>Greyform strukturiert Inhalte, Leistungsseiten, Case Studies und Journal-Beiträge so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, was eine Marke ist, für wen sie ist und warum sie relevant ist.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantische Struktur</span>
            <span class="pillar-value">Sauberes HTML, korrekte Überschriftenhierarchie, Entity-Klarheit</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Strukturierte Daten</span>
            <span class="pillar-value">Schema.org-Markup für Produkte, Kollektionen, FAQs und Markenidentität</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Inhaltliche Tiefe</span>
            <span class="pillar-value">Langform-Seiten die echte Fragen echter Zielgruppen beantworten</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">KI-Lesbarkeit</span>
            <span class="pillar-value">Inhalte strukturiert für ChatGPT, Gemini, Perplexity und Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>Wir beginnen mit einem fokussierten Briefing — Ihre Marke, Ihre Bildwelt, Ihre Zielgruppen. Ein klares Gespräch, ein gemeinsames Verständnis, ein definierter Umfang.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>Wir gestalten das vollständige visuelle System — Typografie, Layout, Bildbehandlung, Seitenrhythmus — bevor wir eine Zeile Code schreiben. In der Regel zwei Überarbeitungsrunden bis zur Freigabe.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Entwicklung</h3>
            <p>Wir bauen die Site mit derselben Sorgfalt wie das Design. Performance, semantisches HTML, SEO-Struktur und Content-System-Architektur als Kernleistungen, nicht als optionale Extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Übergabe</h3>
            <p>Wir übernehmen den technischen Launch und dokumentieren das Content-System klar — damit Ihr Team von Tag eins eigenständig arbeiten kann.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. VERWANDTE LEISTUNGEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <div class="related-item">
          <a href="/furniture-brand-websites" class="related-label related-link">Möbelmarken →</a>
          <p>Digitale Auftritte für Möbelhersteller, Designmarken und Produktunternehmen.</p>
        </div>
        <div class="related-item">
          <span class="related-label">Architekturbüros</span>
          <p>Projekt-Portfolios und Studio-Präsenzen für Architekturbüros. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        <div class="related-item">
          <span class="related-label">Lifestyle Brands</span>
          <p>Editoriale Systeme für Lifestyle-Marken mit Haltung und Ästhetik. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        <div class="related-item">
          <a href="/" class="related-label related-link">Studio-Übersicht →</a>
          <p>Alle Leistungen, ausgewählte Arbeiten und Studio-Ansatz auf der Greyform-Hauptseite.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
