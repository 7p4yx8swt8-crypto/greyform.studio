---
import BaseLayout from "../../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "What types of sales representatives does Greyform work with?",
    a: "We work with independent sales agents and representatives in high-quality product sectors — furniture, interior, lighting, textiles, sanitary, flooring and related design industries. Both individual agents and small representative offices."
  },
  {
    q: "I represent multiple brands — how does the website handle that?",
    a: "That is the heart of what we build for sales representatives. We develop structures that present multiple brands clearly and in an organised way — each line with its own space, without the page becoming confusing. Visitors immediately understand who you work with."
  },
  {
    q: "Do I really need my own website as a sales representative?",
    a: "Yes — and specifically one that positions you as an independent professional. Buyers and architects evaluating a potential collaboration search for you online first. A missing or unprofessional presence costs credibility before the first conversation even takes place."
  },
  {
    q: "Can we update the website ourselves after launch?",
    a: "That is a central goal. We build content systems you can manage independently — adding new brands, updating product lines, changing contact details. No technical knowledge required, no developer needed."
  },
  {
    q: "How does a Greyform project work?",
    a: "We begin with a conversation about your portfolio, your target audience and your goals. Then we develop the concept, design and structure before a single line of code is written. Implementation follows with clear milestones — no endless feedback loops."
  },
  {
    q: "Does Greyform work with smaller budgets?",
    a: "We are not a mass-market service provider, but we are also not a large agency. Our projects are tailored to independent professionals — focused, clear in scope, without hidden costs. Get in touch: we will find the right framework together."
  }
];
---

<BaseLayout
  title="Websites for Independent Sales Representatives — Greyform Studio Berlin"
  description="Greyform builds professional websites and digital presences for independent sales representatives in the furniture, interior and design industry. More credibility, more qualified enquiries."
  lang="en"
>

  <!-- 01. HERO -->
  <section class="section-hero">
    <div class="wrap">
      <div class="eyebrow-row">
        <span class="num">01</span>
        <span class="dash"></span>
        <span class="eyebrow">Sales Representatives</span>
      </div>
      <h1>
        Digital presence for<br />
        <em>independent sales representatives.</em>
      </h1>
      <p class="hero-sub">
        Greyform builds professional websites, brand presentations and digital systems for independent sales agents in the furniture, interior and design industry — so you appear online as convincingly as you do in person.
      </p>
      <a href="#contact" class="btn">Discuss your project →</a>
    </div>
  </section>

  <!-- 02. WHY SALES REPS NEED DIFFERENT WEBSITES -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">The Starting Point</span>
        </div>
        <h2>
          Why sales representatives<br />
          <em>need different websites.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <h3>No professional online presence</h3>
          <p>Many sales representatives are reachable via LinkedIn or an outdated company page — but not truly present. Potential clients and partners form their first impression online. Anyone who fails to convince there loses credibility before the first conversation.</p>
        </div>
        <div class="problem-item">
          <h3>Brands are not shown properly</h3>
          <p>You represent strong brands — but your website does not show that. Product lines, catalogues, collections: all of this needs a clear, organised digital stage. Not a list, but a presentation.</p>
        </div>
        <div class="problem-item">
          <h3>Too few qualified enquiries</h3>
          <p>New contacts often come only through personal networks or trade fairs. A professional website keeps working in the background — bringing enquiries from buyers, architects and planners who are actively searching.</p>
        </div>
        <div class="problem-item">
          <h3>Invisible online</h3>
          <p>When a buyer searches for a sales representative for a specific brand or product category — do you appear? Google and AI systems favour structured, clear content. Without this foundation, you are invisible.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 03. WHY GREYFORM -->
  <section class="section-credibility">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Industry Understanding</span>
        </div>
        <h2>
          Why Greyform understands<br />
          <em>sales representatives from the inside.</em>
        </h2>
      </div>
      <div class="credibility-content">
        <p class="credibility-lead">Greyform did not arrive from outside the industry. The studio's roots lie in the furniture, interior and design world. We understand how the sector works: showrooms, trade fairs, sales territories, brand relationships, procurement cycles.</p>
        <div class="credibility-points">
          <div class="credibility-point">
            <span class="point-label">Multi-brand structure</span>
            <p>We develop pages that present multiple brands simultaneously — clearly and in an organised way, without confusion or visual noise.</p>
          </div>
          <div class="credibility-point">
            <span class="point-label">Audience understood</span>
            <p>Your visitors are buyers, interior architects, planners and project managers. We know how to address and persuade them.</p>
          </div>
          <div class="credibility-point">
            <span class="point-label">No agency overhead</span>
            <p>Greyform is a small, focused studio. You work directly with the people designing and building your website.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 04. WHAT WE BUILD -->
  <section class="section-services-detail">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Services</span>
        </div>
        <h2>
          What we build for<br />
          <em>sales representatives.</em>
        </h2>
      </div>
      <div class="services-detail-grid">
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Professional web presence</h3>
            <p>Your digital business card — clear, convincing and tailored to your market. With everything buyers and partners expect: sales territory, brand portfolio, contact.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Brand and product presentation</h3>
            <p>Each brand you represent gets the space it deserves. Structured, with visual identity, product information and links — as a foundation for acquisition conversations.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Manageable content system</h3>
            <p>New brand in the portfolio? New collection? You update the website yourself — without a developer, without waiting. The system is designed for independent professionals.</p>
          </div>
        </div>
        <div class="service-detail-item">
          <span class="service-num">—</span>
          <div>
            <h3>Search engine optimisation</h3>
            <p>Structured pages that are found on Google and in AI search systems — when buyers search for representatives for specific brands or product categories.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 05. TYPICAL PROJECT SCOPE -->
  <section class="section-scope">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Project Scope</span>
        </div>
        <h2>
          What a typical project<br />
          <em>includes.</em>
        </h2>
      </div>
      <div class="scope-list">
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Strategy conversation about portfolio, audience and positioning</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Concept and page structure based on your representation portfolio</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Visual design — typography, colour system, imagery</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Development with performant, search-engine-optimised technology</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Integration of your brands, catalogues and product information</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Manageable system for independent updates</span>
        </div>
        <div class="scope-item">
          <span class="scope-check">✓</span>
          <span>Launch, domain setup, analytics, handover documentation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 06. AI & SEARCH VISIBILITY -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Visibility</span>
        </div>
        <h2>
          Built for search engines.<br />
          <em>Ready for AI.</em>
        </h2>
      </div>
      <div class="ai-content">
        <p class="ai-lead">When a buyer asks ChatGPT "Who represents brand X in Bavaria?" or searches Google for a sales representative for contract furniture — the structure of your website determines whether your name comes up. Or a competitor's.</p>
        <div class="ai-points">
          <div class="ai-point">
            <h3>Semantic structure</h3>
            <p>Clean HTML semantics and structured content that search engines and AI systems can correctly read and categorise.</p>
          </div>
          <div class="ai-point">
            <h3>Industry-specific keywords</h3>
            <p>Content that uses the terms your target audience actually searches for — brand names, product categories, regions.</p>
          </div>
          <div class="ai-point">
            <h3>Fast and technically clean</h3>
            <p>Load times, Core Web Vitals, mobile optimisation — all standard, not an add-on.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 07. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Questions</span>
        </div>
        <h2>
          Questions we<br />
          <em>hear often.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item, i) => (
          <details class="faq-item">
            <summary class="faq-q">
              <span>{item.q}</span>
              <span class="faq-icon">+</span>
            </summary>
            <p class="faq-a">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 08. RELATED -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Other Industries</span>
        </div>
        <h2>
          Other industries<br />
          <em>we work with.</em>
        </h2>
      </div>
      <div class="related-grid">
        <a href="/en/furniture-brand-websites" class="related-item related-link">
          <span class="related-label">Furniture Brands</span>
          <p>Editorial websites and digital brand systems for furniture manufacturers and design brands.</p>
        </a>
        <a href="/en/interior-brand-websites" class="related-item related-link">
          <span class="related-label">Interior Brands</span>
          <p>Websites and content systems for interior, lighting, textile and home brands.</p>
        </a>
        <a href="/en/architecture-studio-websites" class="related-item related-link">
          <span class="related-label">Architecture Studios</span>
          <p>Digital platforms for project portfolios and studio presences.</p>
        </a>
        <a href="/en/lifestyle-brand-websites" class="related-item related-link">
          <span class="related-label">Lifestyle Brands</span>
          <p>Premium digital experiences for design-led consumer brands.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 09. CTA / CONTACT -->
  <section class="section-contact" id="contact">
    <div class="wrap">
      <div class="eyebrow-row">
        <span class="num">09</span>
        <span class="dash"></span>
        <span class="eyebrow">Contact</span>
      </div>
      <h2>
        Whether a new portfolio,<br />
        repositioning or your first<br />
        <em>professional web presence —</em><br />
        we are listening.
      </h2>
      <a href="mailto:hello@greyform.studio" class="btn">hello@greyform.studio →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 var(--space-md); }
  .section-head { margin-bottom: var(--space-xl); }
  .eyebrow-row { display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-md); }
  .num { font-variant-numeric: tabular-nums; opacity: .4; font-size: .85rem; }
  .dash { flex: 0 0 2rem; height: 1px; background: currentColor; opacity: .2; }
  .eyebrow { font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; opacity: .5; }
  .btn { display: inline-block; margin-top: var(--space-lg); padding: .75rem 1.75rem; border: 1px solid currentColor; font-size: .9rem; letter-spacing: .06em; text-decoration: none; transition: opacity .2s; }
  .btn:hover { opacity: .6; }
  .section-hero { padding: calc(var(--space-xl) * 2.5) 0 calc(var(--space-xl) * 2); }
  .section-hero h1 { font-size: clamp(2.4rem, 5vw, 4.5rem); line-height: 1.05; margin-bottom: var(--space-lg); }
  .hero-sub { max-width: 56ch; font-size: 1.05rem; line-height: 1.65; opacity: .75; }
  .section-problems { padding: calc(var(--space-xl) * 2) 0; }
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: var(--space-xl) var(--space-lg); margin-top: var(--space-xl); }
  .problem-item h3 { font-size: 1rem; margin-bottom: var(--space-sm); }
  .problem-item p { font-size: .9rem; line-height: 1.7; opacity: .7; }
  .section-credibility { padding: calc(var(--space-xl) * 2) 0; }
  .credibility-lead { font-size: 1.1rem; line-height: 1.7; max-width: 64ch; margin-bottom: var(--space-xl); opacity: .85; }
  .credibility-points { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); }
  .credibility-point { border-top: 1px solid currentColor; padding-top: var(--space-md); opacity: .8; }
  .point-label { display: block; font-size: .8rem; letter-spacing: .08em; text-transform: uppercase; margin-bottom: var(--space-sm); opacity: .55; }
  .credibility-point p { font-size: .9rem; line-height: 1.65; }
  .section-services-detail { padding: calc(var(--space-xl) * 2) 0; }
  .services-detail-grid { display: grid; gap: var(--space-lg); }
  .service-detail-item { display: grid; grid-template-columns: 2rem 1fr; gap: var(--space-md); padding: var(--space-lg) 0; border-top: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .service-num { opacity: .3; padding-top: .15rem; }
  .service-detail-item h3 { font-size: 1rem; margin-bottom: var(--space-sm); }
  .service-detail-item p { font-size: .9rem; line-height: 1.7; opacity: .7; }
  .section-scope { padding: calc(var(--space-xl) * 2) 0; }
  .scope-list { display: grid; gap: var(--space-sm); margin-top: var(--space-xl); max-width: 680px; }
  .scope-item { display: flex; align-items: baseline; gap: var(--space-md); padding: var(--space-sm) 0; border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent); font-size: .95rem; line-height: 1.6; }
  .scope-check { opacity: .4; flex-shrink: 0; }
  .section-ai { padding: calc(var(--space-xl) * 2) 0; }
  .ai-lead { font-size: 1.05rem; line-height: 1.7; max-width: 64ch; margin-bottom: var(--space-xl); opacity: .85; }
  .ai-points { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); }
  .ai-point { border-top: 1px solid currentColor; padding-top: var(--space-md); }
  .ai-point h3 { font-size: .95rem; margin-bottom: var(--space-sm); }
  .ai-point p { font-size: .9rem; line-height: 1.65; opacity: .7; }
  .section-faq { padding: calc(var(--space-xl) * 2) 0; }
  .faq-list { max-width: 760px; }
  .faq-item { border-top: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .faq-item:last-child { border-bottom: 1px solid color-mix(in srgb, currentColor 15%, transparent); }
  .faq-q { display: flex; justify-content: space-between; align-items: center; padding: var(--space-md) 0; cursor: pointer; font-size: .95rem; list-style: none; gap: var(--space-md); }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-icon { flex-shrink: 0; opacity: .4; transition: transform .2s; }
  details[open] .faq-icon { transform: rotate(45deg); }
  .faq-a { padding-bottom: var(--space-md); font-size: .9rem; line-height: 1.75; opacity: .7; max-width: 64ch; }
  .section-related { padding: calc(var(--space-xl) * 2) 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: var(--space-lg); margin-top: var(--space-xl); }
  .related-item { padding: var(--space-lg); border: 1px solid color-mix(in srgb, currentColor 12%, transparent); }
  .related-link { text-decoration: none; color: inherit; transition: border-color .2s; }
  .related-link:hover { border-color: currentColor; }
  .related-label { display: block; font-size: .85rem; letter-spacing: .08em; text-transform: uppercase; margin-bottom: var(--space-sm); }
  .related-item p { font-size: .875rem; line-height: 1.65; opacity: .65; margin: 0; }
  .section-contact { padding: calc(var(--space-xl) * 3) 0; }
  .section-contact h2 { font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.1; margin-top: var(--space-lg); }
  @media (max-width: 640px) {
    .problems-grid, .credibility-points, .ai-points { grid-template-columns: 1fr; }
    .service-detail-item { grid-template-columns: 1fr; }
    .service-num { display: none; }
  }
</style>
