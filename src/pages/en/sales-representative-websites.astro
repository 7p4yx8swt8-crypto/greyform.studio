---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "en";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Websites for Independent Sales Representatives",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform builds professional websites, brand presentations and digital systems for independent sales representatives in the furniture, interior and design industry.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Brand Presentation", "Content Systems", "SEO"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Independent sales representatives, sales agencies, commercial agents in the furniture and design industry"
  },
  "knowsAbout": ["Sales representative websites", "Brand presentation", "Multi-brand structure", "B2B communication", "Design industry", "Representative portfolio"]
};

const faqs = [
  {
    q: "What types of sales representatives does Greyform work with?",
    a: "We work with independent sales agents and representatives in high-quality product sectors — furniture, interior, lighting, textiles, sanitary, flooring and related design industries. Both individual agents and small representative offices."
  },
  {
    q: "I represent multiple brands — how does the website handle that?",
    a: "That is the heart of what we build for sales representatives. We develop structures that present multiple brands clearly and in an organised way — each line with its own space, without the page becoming confusing. Visitors immediately understand who you work with."
  },
  {
    q: "Do I really need my own website as a sales representative?",
    a: "Yes — and specifically one that positions you as an independent professional. Buyers and architects evaluating a potential collaboration search for you online first. A missing or unprofessional presence costs credibility before the first conversation even takes place."
  },
  {
    q: "Can we update the website ourselves after launch?",
    a: "That is a central goal. We build content systems you can manage independently — adding new brands, updating product lines, changing contact details. No technical knowledge required, no developer needed."
  },
  {
    q: "How does a Greyform project work?",
    a: "We begin with a conversation about your portfolio, your target audience and your goals. Then we develop the concept, design and structure before a single line of code is written. Implementation follows with clear milestones — no endless feedback loops."
  },
  {
    q: "Do you work with sales representatives outside Germany?",
    a: "Yes. Greyform works internationally. The studio is based in Berlin and handles projects in German and English. We have worked with companies across Europe and are open to projects worldwide."
  }
];
---

<BaseLayout
  title="Websites for Independent Sales Representatives — Greyform Studio Berlin"
  description="Greyform builds professional websites and digital presences for independent sales representatives in the furniture, interior and design industry. More credibility, more qualified enquiries."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digital Presence · Sales Representatives</span>
      </div>
      <h1>
        <span>Digital presence for</span><br />
        <em>independent sales representatives.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform builds professional websites, brand presentations and digital systems for independent sales agents in the furniture, interior and design industry — so you appear online as convincingly as you do in person.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. WHY SALES REPS NEED DIFFERENT WEBSITES -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">The Starting Point</span>
        </div>
        <h2>
          Why sales representatives<br />
          <em>need different websites.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">A sales representative website is not a digital business card. It is a tool that builds trust — before the first conversation takes place.</p>
          <p>Sales representatives operate in a category where personal relationships matter — but the first impression today is formed online. Buyers, interior architects and project managers research your agency before they call. What they find determines whether they call at all.</p>
          <p>Most sales representatives have no website — or one that does not reflect their actual quality. A LinkedIn page, an outdated presence, a PDF portfolio: that is not a digital presence. That is a missed opportunity.</p>
          <p>Greyform develops digital systems for sales representatives that function as professional platforms — multiple brands presented clearly, target audiences addressed directly, independently manageable after launch.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–5</span>
              <span class="stat-label">Weeks from briefing to launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Independently manageable after launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual as standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        The first impression<br />
        is formed online today.<br />
        <em>Before anyone calls.</em>
      </h2>
    </div>
  </section>

  <!-- 3. WHY GREYFORM -->
  <section class="section-credibility">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Industry Understanding</span>
        </div>
        <h2>
          Why Greyform understands<br />
          <em>sales representatives from the inside.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Greyform does not approach sales representatives as an external agency learning a new category. The studio brings direct experience from the furniture and interior industry.</p>
          <p>We understand how sales representatives work — territories, brand relationships, showrooms, trade fairs, procurement cycles, B2B communication. We understand the difference between a product line and a full range, between a trade partner and a contract client.</p>
          <p>We understand that a sales representative website must serve multiple audiences: the buyer evaluating a new supplier, the interior architect specifying a brand, the manufacturer looking for a new agent. Each audience needs something different — a well-structured system can serve all of them.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Multi-brand structure</span>
              <span class="cred-text">Multiple brands presented simultaneously — clearly and in an organised way, with dedicated space for each line</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Sales territory</span>
              <span class="cred-text">Clear communication of region, distribution channels and specialisations — so the right contacts find you</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">B2B communication</span>
              <span class="cred-text">Language and structure for buyers, architects and project managers — not for the end consumer</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Trade fairs & showrooms</span>
              <span class="cred-text">Digital extension of trade fair appearances, showroom appointments and personal presentations</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. COMMON PROBLEMS -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Common Problems</span>
        </div>
        <h2>
          What goes wrong with<br />
          <em>sales representative websites.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>No presence at all</h3>
          <p>Many sales representatives have no website of their own. LinkedIn is not a substitute — it lacks the depth, structure and professionalism that decision-makers expect.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Brands not visible</h3>
          <p>Representing strong brands should show. A simple list with logos is not enough. Product lines, collections and brand worlds need space and context.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>No audience language</h3>
          <p>Sales representative websites often speak to no one directly. Buyers, architects and planners have different needs — a good site addresses each of them clearly.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Invisible online</h3>
          <p>When someone searches for a representative for a specific brand or product category, most sales agents do not appear. Missing SEO structure costs qualified enquiries.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Not manageable</h3>
          <p>New brand in the portfolio, new collection, new territory — if every change requires a developer, the site dates quickly and loses its value as a working tool.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Poor performance</h3>
          <p>Slow, mobile-unoptimised pages damage the impression and the ranking. Technical quality is not a luxury — it is a basic requirement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. OUR APPROACH -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Our Approach</span>
        </div>
        <h2>
          Professionally positioned.<br />
          <em>Independently manageable.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Every Greyform project for sales representatives begins with one question: how do you present yourself — and how should you?</p>
          <p>We read your portfolio, your brands, your audiences — and develop a digital system that represents this reality clearly and convincingly. No templates, no copy-paste. A site that fits your representation structure.</p>
          <p>The result is a presence that appears professional without being inflated. Clearly structured, fast-loading, convincing on all devices. And after launch, completely in your hands — without dependency on external providers for content updates.</p>
          <p>We work with few projects in parallel. That means clear accountability, short communication paths and a level of attention that larger agencies cannot offer.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Approach</span>
            <span class="pillar-value">Structure-led, not template-led</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Speed</span>
            <span class="pillar-value">Weeks, not months</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Audience</span>
            <span class="pillar-value">B2B · Procurement · Architecture · Planning</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Languages</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. WHAT WE BUILD -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Services</span>
        </div>
        <h2>
          What we build for<br />
          <em>sales representatives.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">A sales representative portfolio changes continuously. New brands are added. Collections change. Territories shift.</p>
          <p>That is why we build flexible content systems — not static websites. Every Greyform project is structured so you can update your brand portfolio independently, add new product lines and manage content after launch — without relying on external support for every change.</p>
          <p>The system is designed for the specific needs of sales representatives: structured brand profiles, product overviews, contact and enquiry areas, optional catalogue and download structures. Everything independently operable, fully documented.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Brand and product line presentation</li>
            <li>Sales territory and specialisations</li>
            <li>Contact and enquiry structure</li>
            <li>Optional catalogue and download areas</li>
            <li>No developer required for content updates</li>
            <li>Full documentation at handover</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Visible to people.<br />
        <em>Readable by AI.</em>
      </h2>
    </div>
  </section>

  <!-- 7. AI & SEARCH VISIBILITY -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Search & Visibility</span>
        </div>
        <h2>
          Built for search engines.<br />
          <em>Ready for AI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Search behaviour is changing. Buyers, architects and planners increasingly use AI systems to research suppliers and find sales representatives — before making personal contact.</p>
          <p>When a buyer asks ChatGPT "Who represents brand X in Bavaria?" or searches Google for a sales agent for contract furniture — the structure of your website determines whether your name comes up. Or a competitor's.</p>
          <p>Greyform structures content, brand profiles and service pages so that both search engines and AI systems clearly understand who you represent, where you operate and why you are the right choice. This is not a technical afterthought — it is a fundamental part of how we design digital systems.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantic structure</span>
            <span class="pillar-value">Clean HTML, correct heading hierarchy, entity clarity</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Structured data</span>
            <span class="pillar-value">Schema.org markup for services, FAQs and business identity</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Industry-specific keywords</span>
            <span class="pillar-value">Brand names, product categories, regions — as your audience actually searches</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">AI readability</span>
            <span class="pillar-value">Content structured for ChatGPT, Gemini, Perplexity and Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. PROCESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Process</span>
        </div>
        <h2>
          How a project<br />
          <em>takes shape.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>We begin with a focused conversation — your portfolio, your audiences, your goals. No lengthy discovery phases or expensive strategy documents. A clear conversation, a shared understanding, a defined scope.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>We design the complete visual system — typography, layout, colour, structure — before writing a single line of code. You review, respond and we refine. Typically two rounds of revisions before sign-off.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Development</h3>
            <p>We build the site with the same care as the design. Performance, semantic HTML, SEO structure and content system architecture are treated as core deliverables, not optional extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Handover</h3>
            <p>We handle the technical launch — domain configuration, hosting setup, analytics and sitemap submission. We document the content system clearly and hand everything over so you can work independently from day one.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. RELATED INDUSTRIES -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Related</span>
        </div>
        <h2>
          Other industries<br />
          <em>we work with.</em>
        </h2>
      </div>
      <div class="related-grid">
        <a href="/en/furniture-brand-websites" class="related-item related-link-item">
          <span class="related-label">Furniture Brands</span>
          <p>Editorial websites and digital brand systems for furniture manufacturers and design brands.</p>
        </a>
        <a href="/en/interior-brand-websites" class="related-item related-link-item">
          <span class="related-label">Interior Brands</span>
          <p>Websites and content systems for interior, lighting, textile and home brands.</p>
        </a>
        <a href="/en/architecture-studio-websites" class="related-item related-link-item">
          <span class="related-label">Architecture Studios</span>
          <p>Digital platforms for project portfolios and studio presences.</p>
        </a>
        <a href="/en/lifestyle-brand-websites" class="related-item related-link-item">
          <span class="related-label">Lifestyle Brands</span>
          <p>Premium digital experiences for design-led consumer brands.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 10. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Frequently asked<br />
          <em>questions.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.a
          }
        }))
      })} />
    </div>
  </section>

  <!-- 11. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">Start a project</span>
        </div>
        <h2>
          Let us talk about<br />
          <em>your project.</em>
        </h2>
        <p>Whether you are building a professional web presence for the first time, repositioning your existing portfolio or preparing for new brand partnerships — we look forward to the conversation. We respond within two working days with an honest assessment and a clear next step.</p>
        <a href="mailto:hello@greyform.studio" class="cta-btn">Start the conversation →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .section-statement { padding-block: clamp(64px, 12vw, 140px); }
  .statement-text { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; }
  .statement-text em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .section-statement-dark { background: var(--color-ink, #0d0d0d); padding-block: clamp(64px, 12vw, 140px); }
  .statement-text-dark { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; color: var(--color-paper, #f5f3ef); }
  .statement-text-dark em { font-style: italic; font-weight: 300; color: rgba(245, 243, 239, 0.35); }
  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: clamp(60px, 10vw, 120px); padding-top: clamp(120px, 14vw, 180px); }
  .hero-tag { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: clamp(24px, 4vw, 48px); display: flex; gap: 14px; align-items: center; }
  .hero-tag .dot { width: 6px; height: 6px; background: var(--color-black); border-radius: 50%; }
  .hero h1 { font-size: clamp(44px, 9.2vw, 168px); line-height: 0.92; font-weight: 400; letter-spacing: -0.025em; max-width: 14ch; }
  .hero h1 em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .hero-foot { margin-top: clamp(24px, 4vw, 48px); display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap; }
  .hero-sub { max-width: 46ch; font-size: clamp(15px, 1.4vw, 18px); line-height: 1.55; }
  .hero-meta { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); text-align: right; }
  .hero-meta .row { display: flex; gap: 28px; }
  section { padding-block: var(--section-y); }
  .section-head { margin-bottom: clamp(48px, 8vw, 96px); }
  .eyebrow-row { display: flex; align-items: center; gap: 16px; margin-bottom: clamp(16px, 2vw, 24px); }
  .num { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); }
  .dash { width: 32px; height: 1px; background: var(--muted); opacity: 0.4; }
  .eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }
  h2 { font-size: clamp(32px, 5vw, 72px); font-weight: 400; line-height: 1.05; letter-spacing: -0.02em; }
  h2 em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 8vw, 120px); align-items: start; }
  .col-text p { font-size: clamp(13px, 1.2vw, 15px); line-height: 1.8; color: var(--muted); margin-bottom: 20px; }
  .col-text p.lead { font-size: clamp(16px, 1.6vw, 20px); line-height: 1.5; color: var(--color-black); margin-bottom: 24px; }
  .stat-block { display: flex; flex-direction: column; gap: 32px; padding-top: clamp(16px, 3vw, 48px); border-top: 1px solid var(--color-border, #e0ddd8); }
  .stat-item { display: flex; flex-direction: column; gap: 6px; }
  .stat-value { font-size: clamp(28px, 3vw, 44px); font-weight: 400; letter-spacing: -0.02em; line-height: 1; }
  .stat-label { font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .credibility-list { display: flex; flex-direction: column; padding-top: clamp(16px, 3vw, 48px); }
  .cred-item { padding-block: 20px; border-bottom: 1px solid var(--color-border, #e0ddd8); }
  .cred-item:first-child { border-top: 1px solid var(--color-border, #e0ddd8); }
  .cred-label { display: block; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
  .cred-text { font-size: clamp(13px, 1.2vw, 14px); line-height: 1.6; color: var(--color-black); }
  .section-problems { background: var(--color-ink, #0d0d0d); color: var(--color-paper, #f5f3ef); }
  .section-problems h2 em { color: rgba(245,243,239,0.4); }
