---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "en";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digital Experiences for Architecture Studios",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform designs websites and digital systems for architecture studios and interior design practices. Berlin-based, working worldwide.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Editorial Design", "Content-Systeme"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Architecture Studios, Interior Design Practices, Planning Offices, Design Studios"
  },
  "knowsAbout": ["Architekturbüro-Websites", "Projekt-Portfolios", "Studio-Präsenzen", "Innenarchitektur-Websites"]
};

const faqs = [
  {
    q: "Arbeiten Sie mit Architekturbüros und Innenarchitekturbüros?",
    a: "Ja — mit beiden. Und mit Büros die beides machen. Architekturbüros und Innenarchitekturbüros haben ähnliche digitale Anforderungen: Projekte als Herzstück, klare Kompetenz-Kommunikation, ein System das wächst. Der Unterschied liegt im Ton und in der Bildsprache — und den gestalten wir gemeinsam."
  },
  {
    q: "Wie präsentiert man Architekturprojekte auf einer Website richtig?",
    a: "Projekte brauchen mehr als Bilder. Sie brauchen Kontext: Aufgabenstellung, Ansatz, Material, Besonderheit. Greyform entwickelt Projektsysteme die beides ermöglichen — große atmosphärische Bilder und die inhaltliche Tiefe, die einen Wettbewerber von einem Auftraggeber überzeugt."
  },
  {
    q: "Wie lange dauert ein Projekt?",
    a: "Ein fokussiertes Projekt dauert in der Regel drei bis sechs Wochen von Briefing bis Launch. Der Zeitrahmen hängt vom Umfang des Portfolios und davon ab, ob ein vollständiges Projektsystem oder ein Team-Bereich integriert wird."
  },
  {
    q: "Können wir neue Projekte selbst hinzufügen?",
    a: "Ja — und das ist entscheidend. Architekturbüros gewinnen kontinuierlich neue Projekte. Das Content-System muss es ermöglichen, neue Arbeiten eigenständig zu ergänzen — ohne Entwickler, ohne Wartezeit."
  },
  {
    q: "Arbeiten Sie auch international?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Studios in ganz Europa zusammengearbeitet."
  },
  {
    q: "Können Sie bei SEO und KI-Sichtbarkeit helfen?",
    a: "Ja. Architekturbüros werden zunehmend über KI-Systeme entdeckt — von Bauherren, Entwicklern und Redakteuren die nach Planungspartnern suchen. Wir strukturieren Inhalte so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, was ein Büro macht und wofür es steht."
  }
];
---

<BaseLayout
  title="Websites for Architecture Studios & Interior Design Practices — Greyform Studio Berlin"
  description="Greyform designs project portfolios and digital studio presences for architecture studios and interior design practices. Berlin-based, working worldwide."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digital Experiences · Architecture Studios</span>
      </div>
      <h1>
        <span>Websites for</span><br />
        <em>Architecture Studios.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform designs project portfolios and digital studio presences for architecture studios and interior design practices — precise, independently manageable, clearly positioned.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. PROJEKTE ALS HERZSTÜCK -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Aufgabe</span>
        </div>
        <h2>
          Projects that speak.<br />
          <em>A studio that convinces.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">The website of an architecture studio has a clear task: to convince potential clients — before the first conversation takes place.</p>
          <p>This applies equally to architecture studios and interior design practices. And to studios that do both. The digital presence is often the first impression — and it determines whether a client, developer or investor initiates a conversation or moves on.</p>
          <p>Projects are the heart of it. But projects alone are not enough. An architecture studio needs to communicate digitally: what it can do, how it thinks, what it stands for. This is a communication task, not just a design task.</p>
          <p>Greyform builds digital systems for architecture studios that do both: show projects in their full quality — and make the studio's point of view clearly legible. Not a generic portfolio. A convincing studio portrait.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Weeks from brief to launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">New projects added independently</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual by default</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        Ein Projekt ist mehr<br />
        als seine Bilder.<br />
        <em>Es ist eine Haltung.</em>
      </h2>
    </div>
  </section>

  <!-- 3. ARCHITEKTUR VS INNENARCHITEKTUR -->
  <section class="section-needs">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Architektur & Innenarchitektur</span>
        </div>
        <h2>
          Two disciplines.<br />
          <em>Similar digital needs.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architecture studios and interior design practices have different areas of focus — but similar digital needs.</p>
          <p>Architecture studios often communicate in a B2B context: developers, investors, public clients. The website needs to convey competence, experience and a clear point of view. Projects need depth: brief, approach, context, outcome.</p>
          <p>Interior design practices often move between B2B and B2C. The visual language is more atmospheric, the audiences more varied — private clients, hotel projects, retail, workplace. The website needs to do both: convince and seduce.</p>
          <p>Practices that do both need a structure that can show both — without compromising clarity. We build systems that make this possible.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Architecture Studios</span>
              <span class="cred-text">Competence communication, project depth, competitions, awards, team and studio profile</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Interior Design Practices</span>
              <span class="cred-text">Atmospheric visual language, spatial feeling, materials, B2C and B2B communication</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Mixed Practices</span>
              <span class="cred-text">Flexible structures that show architecture and interior design as clearly distinct but coherent</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Project Systems</span>
              <span class="cred-text">Independently manageable portfolios — new projects added in minutes, without a developer</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Architekturbüro-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Images without context</h3>
          <p>Beautiful project photography — but no text that explains what the brief was, how the studio thought about it and what makes the project distinctive. Potential clients see outcomes but do not understand the competence behind them.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Outdated portfolio</h3>
          <p>Websites that require a developer to update quickly fall behind the actual state of the studio. New projects are missing. The site no longer shows what the practice can do today.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>No clear studio portrait</h3>
          <p>Many architecture studios show projects but very little studio. Who are the people behind it? What is the point of view? What distinguishes this practice? These questions remain unanswered.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Poor discoverability</h3>
          <p>Architecture studios that are barely discoverable through Google or AI systems — because the website has no semantic structure and the projects are not built as machine-readable content.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>No international reach</h3>
          <p>Practices with international projects and ambitions — but single-language websites. International clients, publications and juries remain out of reach.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Template portfolio</h3>
          <p>Generic portfolio themes that make every studio look the same. The visual system communicates nothing about the practice's point of view — and that is a missed opportunity.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Not a portfolio template.<br />
          <em>A studio portrait.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Every Greyform project begins with the question: what makes this studio distinctive?</p>
          <p>Not: which template fits best? But: what is the point of view, the visual language, the way of thinking — and how do we translate that into a digital system that communicates exactly that?</p>
          <p>The result is a website that feels like a natural expression of the studio. Not a generic portfolio. A presence that builds trust before the first conversation — and that grows independently with the practice after launch.</p>
          <p class="internal-links">See our work: <a href="/en/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/en/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Approach</span>
            <span class="pillar-value">Studio portrait, not project list</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Pace</span>
            <span class="pillar-value">Weeks, not months</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Aesthetic</span>
            <span class="pillar-value">Precise · Architectural</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Languages</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. PROJEKTSYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Projektsysteme</span>
        </div>
        <h2>
          New projects.<br />
          <em>Added independently.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architecture studios continuously win new projects. The digital system needs to keep up.</p>
          <p>This is why we build flexible project systems — not static websites. Every Greyform project is structured so that your team can independently add new projects, update existing ones and continuously develop the portfolio — without a developer, without waiting.</p>
          <p>The system is designed around the needs of a planning practice: structured project entries with images, texts, categories and metadata. Filter functions by type, scale or year. Team pages. Press and awards section. All independent, all in the browser.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Project management with images and texts</li>
            <li>Categories by type and scale</li>
            <li>Team and studio pages</li>
            <li>Press and awards section</li>
            <li>No developer required for new projects</li>
            <li>Full documentation at handover</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/en/work/the-grey" class="work-link">
            <div class="work-media">
              <img src="/work/thegrey-berlin/00-cover.jpg" alt="thegrey.berlin — Brand Identity & Website for a Berlin Interior Label" loading="lazy" class="img-bottom" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey"><span>View project</span> <span class="arr">→</span></a>
        </article>
        <article class="work-item">
          <a href="/en/work/jina-kim" class="work-link">
            <div class="work-media">
              <img src="/work/jina-kim/cover.jpg" alt="Ji-Na Kim — Editorial Brand Site" loading="lazy" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim"><span>View project</span> <span class="arr">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Sichtbar für Menschen.<br />
        <em>Verständlich für KI.</em>
      </h2>
    </div>
  </section>

  <!-- 8. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Built for search.<br />
          <em>Ready for AI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architecture studios are increasingly discovered through AI systems — by developers, clients, editors and juries looking for planning partners.</p>
          <p>A website without semantic structure and machine-readable content is invisible to these systems — regardless of how good the projects are. AI systems can only recommend what they understand.</p>
          <p>Greyform structures project pages, studio texts, awards and press coverage so that both search engines and AI systems can clearly understand what a studio does, where it operates and what it stands for.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantic Structure</span>
            <span class="pillar-value">Clean HTML, correct hierarchy, entity clarity</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Structured Data</span>
            <span class="pillar-value">Schema.org markup for studio, projects and services</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Content Depth</span>
            <span class="pillar-value">Project descriptions that communicate competence and point of view</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">AI Readability</span>
            <span class="pillar-value">Content structured for ChatGPT, Gemini, Perplexity and Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Brief & Discovery</h3>
            <p>We begin with a focused brief — your studio, your projects, your audiences. A clear conversation, a shared understanding, a defined scope.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>We design the full visual system — typography, layout, image treatment, project page structure — before writing a line of code. Typically two rounds of revisions before sign-off.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Build</h3>
            <p>We build the site with the same care as the design. Performance, semantic HTML, SEO structure and project system architecture as core deliverables.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Handover</h3>
            <p>We handle the technical launch and document the project system clearly — so your team can add new projects independently from day one.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. VERWANDTE LEISTUNGEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <div class="related-item">
          <a href="/en/furniture-brand-websites" class="related-label related-link">Furniture Brands →</a>
          <p>Digital experiences for furniture manufacturers, design brands and product companies.</p>
        </div>
        <div class="related-item">
          <a href="/en/interior-brand-websites" class="related-label related-link">Interior Brands →</a>
          <p>Websites and content systems for interior, lighting, textile and home brands.</p>
        </div>
        <div class="related-item">
          <span class="related-label">Lifestyle Brands</span>
          <p>Editorial systems for lifestyle brands with attitude and aesthetics. <span class="related-soon">— Page coming soon</span></p>
        </div>
        <div class="related-item">
          <a href="/en/" class="related-label related-link">Studio Overview →</a>
          <p>All services, selected work and studio approach on the Greyform homepage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      })} />
    </div>
  </section>

  <!-- 12. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">11</span>
          <span class="dash"></span>
          <span class="eyebrow">Projekt starten</span>
        </div>
        <h2>
          Lassen Sie uns über<br />
          <em>Ihr Studio sprechen.</em>
        </h2>
        <p>Whether you are launching a new studio, relaunching an established practice or building a project system — we would be happy to discuss it. We respond within two working days with an honest assessment.</p>
        <a href="mailto:hello@greyform.studio" class="cta-btn">Start the conversation →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .section-statement { padding-block: clamp(64px, 12vw, 140px); }
  .statement-text { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; }
  .statement-text em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .section-statement-dark { background: var(--color-ink, #0d0d0d); padding-block: clamp(64px, 12vw, 140px); }
  .statement-text-dark { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; color: var(--color-paper, #f5f3ef); }
  .statement-text-dark em { font-style: italic; font-weight: 300; color: rgba(245, 243, 239, 0.35); }
  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: clamp(60px, 10vw, 120px); padding-top: clamp(120px, 14vw, 180px); }
  .hero-tag { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: clamp(24px, 4vw, 48px); display: flex; gap: 14px; align-items: center; }
  .hero-tag .dot { width: 6px; height: 6px; background: var(--color-black); border-radius: 50%; }
  .hero h1 { font-size: clamp(44px, 9.2vw, 168px); line-height: 0.92; font-weight: 400; letter-spacing: -0.025em; max-width: 14ch; }
  .hero h1 em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .hero-foot { margin-top: clamp(24px, 4vw, 48px); display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap; }
  .hero-sub { max-width: 46ch; font-size: clamp(15px, 1.4vw, 18px); line-height: 1.55; }
  .hero-meta { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); text-align: right; }
  .hero-meta .row { display: flex; gap: 28px; }
