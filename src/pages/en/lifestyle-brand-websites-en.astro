---
import BaseLayout from "../../layouts/BaseLayout.astro";

const lang = "en";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digital Experiences for Lifestyle Brands",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet editoriale Websites und digitale Systeme für Lifestyle-Marken, Design-Labels und designgetriebene Verbrauchermarken. Studio in Berlin, international tätig.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Editorial Design", "Content-Systeme", "Digitale Markenstrategie"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Lifestyle Brands, Design Labels, Design-led Consumer Brands, Premium Consumer Brands"
  },
  "knowsAbout": ["Lifestyle-Marken-Websites", "Design-Label-Websites", "Premium-Consumer-Brand-Websites", "Editoriale Markensysteme"]
};

const faqs = [
  {
    q: "What is a lifestyle brand — and what does it need digitally?",
    a: "A lifestyle brand is a brand that sells not only products but a point of view. It defines a way of living, consuming, positioning oneself. Digitally, this means the website must communicate that point of view immediately — atmospheric, precise, with an editorial voice that is distinctive."
  },
  {
    q: "How does a lifestyle brand differ from an interior brand?",
    a: "Interior brands focus on living environments — furniture, lighting, textiles, spatial design. Lifestyle brands are broader: they can encompass fashion, food, beauty, wellness, travel or a combination. What unites them: a clear aesthetic point of view and the ability to build a community around the brand."
  },
  {
    q: "Which lifestyle brands does Greyform work with?",
    a: "We work with design-led consumer brands that have a clear aesthetic position. Not mass market, not generic labels. Brands that have something to say — and want to say it digitally in the same way they say it everywhere else."
  },
  {
    q: "How long does a project take?",
    a: "A focused project typically takes three to six weeks from brief to launch. The timeline depends on the scope of content, the complexity of the content system and whether a shop system is integrated."
  },
  {
    q: "Can we manage the website ourselves after launch?",
    a: "Yes — and this is essential. Lifestyle brands live on currency: new collections, new content, new campaigns. The content system needs to make this possible independently — without a developer, without waiting."
  },
  {
    q: "Can you help with SEO and AI visibility?",
    a: "Yes. Lifestyle brands are increasingly discovered through AI systems — by journalists, buyers, influencers and consumers looking for inspiration. We structure content so that both search engines and AI systems can clearly understand what a brand stands for."
  }
];
---

<BaseLayout
  title="Digital Experiences for Lifestyle Brands — Greyform Studio Berlin"
  description="Greyform designs editorial websites and digital systems for lifestyle brands and design-led consumer brands. Berlin-based, working worldwide."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digital Experiences · Lifestyle Brands</span>
      </div>
      <h1>
        <span>Digital Experiences</span><br />
        <em>for Lifestyle Brands.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform designs editorial websites and digital systems for lifestyle brands and design-led consumer brands — with attitude, aesthetics and an editorial voice that holds.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. WAS EINE LIFESTYLE-MARKE AUSMACHT -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Herausforderung</span>
        </div>
        <h2>
          More than a product.<br />
          <em>A point of view.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">A lifestyle brand does not only sell what it makes. It sells how one should live.</p>
          <p>This is the fundamental difference from a pure product brand. A consumer does not buy a candle — they buy a mood, a sense of belonging, a version of themselves. The website needs to facilitate this transfer. It needs not only to show products, it needs to build a world.</p>
          <p>This is achieved through editorial imagery, a clear editorial voice, a content system that continuously writes new chapters — and a visual system that remains recognisable across every format and every channel.</p>
          <p>Greyform builds digital systems for lifestyle brands that do exactly this: communicate a point of view, build a world, gather a community. Not a generic online shop. An editorial platform that makes brand and product inseparable.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Weeks from brief to launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Manageable by your team after launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual by default</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        Eine Lifestyle-Marke<br />
        verkauft keine Produkte.<br />
        <em>Sie verkauft eine Welt.</em>
      </h2>
    </div>
  </section>

  <!-- 3. WAS LIFESTYLE-MARKEN BRAUCHEN -->
  <section class="section-needs">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Was Lifestyle-Marken brauchen</span>
        </div>
        <h2>
          Build a world.<br />
          <em>Gather a community.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">The digital presence of a lifestyle brand is more than a website. It is the home of the brand online.</p>
          <p>This means: a visual system that carries the brand's point of view — consistent, recognisable, distinctive. A content system that makes room for campaigns, collections, collaborations, editorials and insight. And a structure that enables both inspiration and conversion — without one undermining the other.</p>
          <p>Lifestyle brands need a website that breathes with them. That can absorb new chapters without losing its face. That works as powerfully on Instagram as on desktop. That can be maintained independently by a small team — without losing quality.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Visual System</span>
              <span class="cred-text">Typography, visual language and colour world as a coherent system — that works across every format</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Editorial Platform</span>
              <span class="cred-text">Journal, campaigns, collections and collaborations as an integrated part of the brand architecture</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Community & Engagement</span>
              <span class="cred-text">Structures that create belonging — newsletter, events, membership, curatorial content</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Conversion without compromise</span>
              <span class="cred-text">Shop integration that fits the brand — not the other way around. Products in the right context, not in a catalogue</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Lifestyle-Marken-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Shop instead of brand</h3>
          <p>Lifestyle brands that build their website like an e-commerce shop lose what matters most: the world. When you land straight in a product grid on the homepage, the magic is gone before it had a chance to form.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Instagram aesthetics on desktop</h3>
          <p>What works on Instagram does not automatically work on a website. Square images, short captions, fast scrolls — that is a different language. A website needs depth, rhythm, space.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>No content system</h3>
          <p>Lifestyle brands that cannot update their website independently fall behind. New collections arrive online too late. Campaigns are not extended digitally. The site dates quickly.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Visual disconnect between channels</h3>
          <p>Instagram looks different from the website, the website different from the newsletter. No coherent visual system. The brand feels arbitrary — even if the products are not.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>No editorial voice</h3>
          <p>Many lifestyle brands have great products and great images — but no voice. No journal. No perspective. No content that gives people a reason to come back.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Invisible to AI</h3>
          <p>Beautiful images, but no structured content. AI systems asked for lifestyle recommendations cannot understand this brand — and do not recommend it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Point of view first.<br />
          <em>Products in context.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Every Greyform project begins with the question: what is the world of this brand?</p>
          <p>Not: how many products does it have? But: what is its point of view? Its visual language? Its editorial voice? What does it feel like to be part of this brand?</p>
          <p>Only once these questions are answered do we start designing. The result is a digital system that makes attitude and product inseparable — a website people visit because it is interesting, and buy from because they are convinced.</p>
          <p class="internal-links">See our work: <a href="/en/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/en/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Approach</span>
            <span class="pillar-value">Point of view first, products in context</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Pace</span>
            <span class="pillar-value">Weeks, not months</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Aesthetic</span>
            <span class="pillar-value">Editorial · Distinctive</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Languages</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CONTENT-SYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Content-Systeme</span>
        </div>
        <h2>
          Always current.<br />
          <em>Always on brand.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Lifestyle brands live on currency. New collections. New campaigns. New collaborations. The content system needs to keep up.</p>
          <p>This is why we build flexible content systems — not static websites. Every Greyform project is structured so that your team can launch collections, publish campaigns, write journal entries and manage content independently — without a developer, without waiting.</p>
          <p>The system is designed around the editorial needs of a lifestyle brand: collection and product management, journal and campaign section, newsletter integration, event pages. All independent, all in the browser, all on brand.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Collection and product management</li>
            <li>Journal and campaign section</li>
            <li>Collaboration and editorial pages</li>
            <li>Newsletter and community integration</li>
            <li>No developer required for content updates</li>
            <li>Full documentation at handover</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/en/work/the-grey" class="work-link">
            <div class="work-media">
              <img src="/work/thegrey-berlin/00-cover.jpg" alt="thegrey.berlin — Brand Identity & Website for a Berlin Lifestyle Label" loading="lazy" class="img-bottom" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey"><span>View project</span> <span class="arr">→</span></a>
        </article>
        <article class="work-item">
          <a href="/en/work/jina-kim" class="work-link">
            <div class="work-media">
              <img src="/work/jina-kim/cover.jpg" alt="Ji-Na Kim — Editorial Brand Site" loading="lazy" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim"><span>View project</span> <span class="arr">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Sichtbar für Menschen.<br />
        <em>Verständlich für KI.</em>
      </h2>
    </div>
  </section>

  <!-- 8. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Built for search.<br />
          <em>Ready for AI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Lifestyle brands are discovered today through more channels than ever — and AI systems play a growing role in this.</p>
          <p>When someone asks ChatGPT "Which lifestyle brands with a sustainable approach exist in Berlin?" — the structure of your website determines whether your name comes up. Not your follower count. Not your Instagram reach. Your content.</p>
          <p>Greyform structures content, service pages, journal articles and product pages so that both search engines and AI systems can clearly understand what a brand is, what it stands for and why it matters.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantic Structure</span>
            <span class="pillar-value">Clean HTML, correct heading hierarchy, entity clarity</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Structured Data</span>
            <span class="pillar-value">Schema.org markup for products, collections, FAQs and brand identity</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Content Depth</span>
            <span class="pillar-value">Journal and campaigns that answer real questions from real audiences</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">AI Readability</span>
            <span class="pillar-value">Content structured for ChatGPT, Gemini, Perplexity and Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Brief & Discovery</h3>
            <p>We begin with a focused brief — your brand, your world, your audiences. A clear conversation, a shared understanding, a defined scope.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>We design the full visual system — typography, layout, image treatment, page rhythm — before writing a line of code. Typically two rounds of revisions before sign-off.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Build</h3>
            <p>We build the site with the same care as the design. Performance, semantic HTML, SEO structure and content system architecture as core deliverables, not optional extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Handover</h3>
            <p>We handle the technical launch and document the content system clearly — so your team can publish new content independently from day one.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. VERWANDTE LEISTUNGEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <div class="related-item">
          <a href="/en/furniture-brand-websites" class="related-label related-link">Furniture Brands →</a>
          <p>Digital experiences for furniture manufacturers, design brands and product companies.</p>
        </div>
        <div class="related-item">
          <a href="/en/interior-brand-websites" class="related-label related-link">Interior Brands →</a>
          <p>Websites and content systems for interior, lighting, textile and home brands.</p>
        </div>
        <div class="related-item">
          <a href="/en/architecture-studio-websites" class="related-label related-link">Architecture Studios →</a>
          <p>Project portfolios and studio presences for architecture studios and interior design practices.</p>
        </div>
        <div class="related-item">
          <a href="/en/" class="related-label related-link">Studio Overview →</a>
          <p>All services, selected work and studio approach on the Greyform homepage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": { "@type": "Answer", "text": f.a }
        }))
      })} />
    </div>
  </section>

  <!-- 12. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">11</span>
          <span class="dash"></span>
          <span class="eyebrow">Projekt starten</span>
        </div>
        <h2>
          Lassen Sie uns über<br />
          <em>Ihre Marke sprechen.</em>
        </h2>
        <p>Whether you are launching a new collection, repositioning an established lifestyle brand or building a stronger digital presence — we would be happy to discuss the project. We respond within two working days with an honest assessment.</p>
        <a href="mailto:hello@greyform.studio" class="cta-btn">Start the conversation →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .section-statement { padding-block: clamp(64px, 12vw, 140px); }
  .statement-text { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; }
  .statement-text em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .section-statement-dark { background: var(--color-ink, #0d0d0d); padding-block: clamp(64px, 12vw, 140px); }
  .statement-text-dark { font-size: clamp(32px, 5.5vw, 80px); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 16ch; color: var(--color-paper, #f5f3ef); }
  .statement-text-dark em { font-style: italic; font-weight: 300; color: rgba(245, 243, 239, 0.35); }
  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding-bottom: clamp(60px, 10vw, 120px); padding-top: clamp(120px, 14vw, 180px); }
  .hero-tag { font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted); margin-bottom: clamp(24px, 4vw, 48px); display: flex; gap: 14px; align-items: center; }
  .hero-tag .dot { width: 6px; height: 6px; background: var(--color-black); border-radius: 50%; }
  .hero h1 { font-size: clamp(44px, 9.2vw, 168px); line-height: 0.92; font-weight: 400; letter-spacing: -0.025em; max-width: 14ch; }
  .hero h1 em { font-style: italic; font-weight: 300; color: var(--color-stone); }
  .hero-foot { margin-top: clamp(24px, 4vw, 48px); display: flex; justify-content: space-between; align-items: flex-end; gap: 40px; flex-wrap: wrap; }
  .hero-sub { max-width: 46ch; font-size: clamp(15px, 1.4vw, 18px); line-height: 1.55; }
  .hero-meta { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); text-align: right; }
  .hero-meta .row { display: flex; gap: 28px; }
  section { padding-block: var(--section-y); }
  .section-head { margin-bottom: clamp(48px, 8vw, 96px); }
  .eyebrow-row { display: flex; align-items: center; gap: 16px; margin-bottom: clamp(16px, 2vw, 24px); }
  .num { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); }
  .dash { width: 32px; height: 1px; background: var(--muted); opacity: 0.4; }
