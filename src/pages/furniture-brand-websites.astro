---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "de";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digitale Auftritte für Möbelmarken",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet editoriale Websites, Content-Systeme und digitale Plattformen für Möbelmarken, Möbelhersteller, Lichtmarken und Interior-Produktmarken. Studio in Berlin, international tätig.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Editorial Design", "Content-Systeme", "Digitale Markenstrategie"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Möbelmarken, Möbelhersteller, Lichtmarken, Interior-Produktmarken, Design-getriebene Produktmarken"
  },
  "knowsAbout": ["Möbelmarken-Websites", "Kollektionspräsentation", "Messedigitalisierung", "Händlernetzwerk-Kommunikation", "Premium-Positionierung", "Editoriale Content-Systeme"]
};

const faqs = [
  {
    q: "Sind Sie auf Websites für Möbelmarken und Möbelhersteller spezialisiert?",
    a: "Ja. Greyform arbeitet mit Möbelmarken, Möbelherstellern, Lichtmarken und Interior-Produktmarken. Wir verstehen die spezifischen Anforderungen der Kategorie — Kollektionsstruktur, spezifikationsgetriebener Einkauf, Händlernetzwerk-Kommunikation, Messeauftritte und Premium-Positionierung — und gestalten digitale Systeme, die all das leisten."
  },
  {
    q: "Wie lange dauert ein Website-Projekt für eine Möbelmarke?",
    a: "Ein fokussiertes Projekt dauert in der Regel drei bis sechs Wochen von Briefing bis Launch. Der Zeitrahmen hängt vom Umfang der Inhalte, der Anzahl der Produktlinien und davon ab, ob ein Content-System integriert wird."
  },
  {
    q: "Können wir die Website nach dem Launch selbst pflegen?",
    a: "Ja — und das ist ein zentrales Ziel unserer Arbeit. Wir entwickeln flexible Content-Systeme, mit denen Ihr Team Kollektionen aktualisieren, Produkte hinzufügen und Inhalte eigenständig pflegen kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein."
  },
  {
    q: "Arbeiten Sie auch mit Möbelmarken außerhalb Deutschlands?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Marken in ganz Europa zusammengearbeitet und sind offen für Projekte weltweit."
  },
  {
    q: "Können Sie bei SEO und KI-Sichtbarkeit für unsere Möbelmarke helfen?",
    a: "Ja. SEO und strukturierte Inhalte sind von Anfang an Teil jedes Projekts — semantische Struktur, Metadaten, Performance und Content-Architektur werden von Beginn an berücksichtigt. Wir strukturieren Inhalte auch so, dass sie von KI-Systemen wie ChatGPT, Gemini und Google AI Overviews klar verstanden werden — die zunehmend von Käufern, Planern und Journalisten genutzt werden, um Möbelmarken zu entdecken."
  },
  {
    q: "Arbeiten Sie auch für Interior-Marken und Architekturbüros?",
    a: "Ja. Neben Möbelmarken arbeitet Greyform mit Interior-Marken, Architekturbüros und Lifestyle-Marken. Jede Kategorie hat ihre eigenen digitalen Anforderungen — wir gestalten Systeme, die auf die spezifischen Kommunikationsbedürfnisse jeder Marke zugeschnitten sind."
  }
];
---

<BaseLayout
  title="Digitale Auftritte für Möbelmarken — Greyform Studio Berlin"
  description="Greyform gestaltet editoriale Websites, Content-Systeme und digitale Plattformen für Möbelmarken, Hersteller und Interior-Produktmarken. Studio in Berlin, international tätig."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digitale Auftritte · Möbelmarken</span>
      </div>
      <h1>
        <span>Digitale Auftritte</span><br />
        <span>für Möbel-</span><br />
        <em>marken.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform gestaltet editoriale Websites, Content-Systeme und digitale Plattformen für Möbelmarken, Hersteller und design-getriebene Produktmarken — präzise umgesetzt, nach dem Launch eigenständig pflegbar.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. WARUM MÖBELMARKEN ANDERE WEBSITES BRAUCHEN -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Herausforderung</span>
        </div>
        <h2>
          Warum Möbelmarken<br />
          <em>andere Websites brauchen.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Möbelmarken-Website ist kein Produktkatalog. Sie ist ein Markenerlebnis — und die meisten Websites in dieser Kategorie liefern keines.</p>
          <p>Möbelmarken operieren in einer Kategorie, in der das physische Produkt aspirativ, haptisch und tief mit einem Lebensgefühl verknüpft ist. Die Website muss dieses Gewicht tragen. Sie muss Kollektionen mit editorialer Präzision präsentieren, Handwerk und Materialien klar kommunizieren und eine Markengeschichte erzählen, die einem Käufer — ob Privatkunde, Innenarchitekt oder Handelseinkäufer — einen Grund gibt, sich für diese Marke zu entscheiden.</p>
          <p>Generische Website-Builder und Template-basierte Agenturen verstehen das nicht. Sie produzieren Sites, die wie jede andere Möbelwebsite aussehen — Produktgrids, Slider-Karussells, Stockfotografie. Das Ergebnis ist ein digitaler Auftritt, der aktiv das bereits geleistete Markeninvestment untergräbt.</p>
          <p>Greyform arbeitet anders. Wir entwickeln digitale Systeme für Möbelmarken, die als editoriale Plattformen funktionieren — ruhig, präzise, markengeführt — und die nach dem Launch von Ihrem eigenen Team gepflegt und erweitert werden können.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Wochen von Briefing bis Launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Nach dem Launch eigenständig pflegbar</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual als Standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. WARUM GREYFORM MÖBELMARKEN VERSTEHT -->
  <section class="section-credibility">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Branchenverständnis</span>
        </div>
        <h2>
          Warum Greyform Möbelmarken<br />
          <em>von innen versteht.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Greyform nähert sich Möbelmarken nicht als externe Agentur, die eine neue Kategorie kennenlernt. Das Studio bringt direkte Erfahrung aus der Möbel- und Einrichtungsbranche mit.</p>
          <p>Wir verstehen, wie Möbelmarken auf den Markt kommen — über Händlernetzwerke, Fachausstellungen, Planungskanäle und direkte Verbraucherplattformen. Wir verstehen den Unterschied zwischen einem Kollektionslaunch und einem Produktupdate, zwischen einem Messeauftritt und einer Verbraucherkampagne, zwischen einer Materialgeschichte und einem Preisargument.</p>
          <p>Wir verstehen, dass eine Möbelmarken-Website mehrere Zielgruppen gleichzeitig bedienen muss: den Endkunden, der die Marke zum ersten Mal entdeckt, den Innenarchitekten, der ein Produkt für ein Projekt spezifiziert, den Handelseinkäufer, der einen neuen Lieferanten bewertet, und den Journalisten, der eine Geschichte sucht. Jede dieser Zielgruppen braucht etwas anderes — und ein gut strukturiertes digitales System kann alle bedienen, ohne Kompromisse.</p>
          <p>Dieses Verständnis bringen wir in jedes Möbelmarkenprojekt ein. Nicht aus einem Brief abgeleitet, sondern aus Erfahrung aufgebaut.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Kollektionen</span>
              <span class="cred-text">Saisonale und permanente Kollektionsarchitektur, Variantenverwaltung und editoriale Präsentation</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Handel & Händler</span>
              <span class="cred-text">Händlerfinder, Handelsportale, Spezifikationsdownloads und B2B-Kommunikationsstrukturen</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Messen</span>
              <span class="cred-text">Digitale Begleitung für Salone del Mobile, imm cologne, Maison & Objet und andere Branchenevents</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Premium-Positionierung</span>
              <span class="cred-text">Visuelle Systeme, die Qualität, Handwerk und Markenautorität kommunizieren — ohne es direkt auszusprechen</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Möbelmarken-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Template-Ästhetik</h3>
          <p>Generische Themes und Drag-and-Drop-Builder erzeugen Sites, die von Mitbewerbern nicht zu unterscheiden sind. Das visuelle System kommuniziert nichts über die Marke.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Produkt zuerst, Marke zuletzt</h3>
          <p>Die meisten Möbelwebsites führen mit Produktgrids und Preisen. Markengeschichte, Materialphilosophie und Designprozess — die Dinge, die einen Premiumpreis rechtfertigen — fehlen oder sind kaum auffindbar.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>Kein Content-System</h3>
          <p>Websites, die ohne Entwickler nicht aktualisiert werden können, veralten innerhalb von Monaten. Neue Kollektionen werden nicht gelauncht. Presseberichte werden nicht ergänzt. Die Site hört auf, als Marketing-Werkzeug zu funktionieren.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Schwache SEO-Architektur</h3>
          <p>Möbelmarken investieren in hochwertige Fotografie, vernachlässigen aber die semantische Struktur, Ladegeschwindigkeit und Metadaten, die bestimmen, ob diese Investition über die Suche irgendjemanden erreicht.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Nicht für internationale Zielgruppen gebaut</h3>
          <p>Einsprachige Websites ohne hreflang-Struktur, lokalisierte Inhalte und internationale SEO lassen erhebliche Märkte unerschlossen — besonders für Marken, die Handelskunden in ganz Europa ansprechen möchten.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Langsame Performance</h3>
          <p>Bildlastige Möbelwebsites laden häufig langsam, was sowohl die Nutzererfahrung als auch die Suchmaschinen-Rankings schädigt. Performance sollte von Anfang an als Design-Constraint verstanden werden.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Editoriales Design.<br />
          <em>Präzise Umsetzung.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Jedes Greyform-Projekt beginnt mit der Marke, nicht mit dem Template.</p>
          <p>Wir lesen die visuelle Sprache, die eine Möbelmarke bereits besitzt — in ihren Produkten, ihrer Fotografie, ihren Printmaterialien — und gestalten ein digitales System, das diese Sprache fortsetzt, anstatt sie in etwas Generisches zu übersetzen.</p>
          <p>Das Ergebnis ist eine Website, die sich wie eine Erweiterung der Marke liest. Typografie, Weißraum, Bildbehandlung, Seitenstruktur und Navigation werden als Teil eines kohärenten Ganzen betrachtet. Nicht aus Komponenten zusammengesetzt, sondern von Grund auf um das gestaltet, was diese spezifische Marke kommunizieren muss.</p>
          <p>Wir arbeiten mit wenigen Projekten parallel. Das bedeutet klare Verantwortung, kurze Kommunikationswege und ein Maß an Aufmerksamkeit, das größere Agenturen nicht bieten können. Von Briefing bis Launch in Wochen, nicht Monaten.</p>
          <p class="internal-links">Referenzprojekte: <a href="/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Ansatz</span>
            <span class="pillar-value">Markengeführt, nicht templategeführt</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Tempo</span>
            <span class="pillar-value">Wochen, nicht Monate</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Ästhetik</span>
            <span class="pillar-value">Editorial · Architektonisch</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Sprachen</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. FLEXIBLE CONTENT-SYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Content-Systeme</span>
        </div>
        <h2>
          Websites, die Ihr Team<br />
          <em>eigenständig pflegen kann.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Eine Möbelmarken-Website ist nie fertig. Kollektionen ändern sich. Neue Produkte werden gelauncht. Presseberichte kommen hinzu. Messeauftritte müssen angekündigt werden.</p>
          <p>Deshalb entwickeln wir flexible Content-Systeme — keine statischen Websites. Jedes Greyform-Projekt ist so strukturiert, dass Ihr Team Kollektionen aktualisieren, Produkte hinzufügen, Journal-Beiträge veröffentlichen und Inhalte nach dem Launch pflegen kann — ohne für jede Änderung auf einen Entwickler angewiesen zu sein.</p>
          <p>Das System ist auf die redaktionellen Bedürfnisse einer Möbelmarke ausgelegt: strukturierte Produkteinträge, Kollektionsübersichten, Material- und Spezifikationsseiten, Presse- und Journal-Bereiche. Jeder Bereich kann unabhängig, im Browser, von jedem Teammitglied aktualisiert werden.</p>
          <p>Wir dokumentieren das System und übergeben es am Ende jedes Projekts vollständig. Es gehört Ihnen.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Kollektion- und Produktverwaltung</li>
            <li>Journal- und Pressebereich</li>
            <li>Team- und About-Seiten</li>
            <li>Projekt- und Case-Study-Einträge</li>
            <li>Kein Entwickler für Content-Updates erforderlich</li>
            <li>Vollständige Dokumentation bei Übergabe</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. EDITORIALE INHALTE -->
  <section class="section-editorial">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Editoriale Inhalte</span>
        </div>
        <h2>
          Jenseits der Produkte:<br />
          <em>editoriale Inhalte.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Die stärksten Möbelmarken veröffentlichen nicht nur Produkte. Sie veröffentlichen Ideen.</p>
          <p>Materialgeschichten. Design-Thinking. Referenzen und Installationen. Kollaborationsprofile. Neuigkeiten aus dem Studio. Expertise, die nirgendwo sonst zu finden ist. Diese Art von Inhalt füllt nicht nur ein Journal — sie baut langfristige Sichtbarkeit, Autorität und Vertrauen bei genau den Zielgruppen auf, die eine Möbelmarke erreichen muss.</p>
          <p>Greyform entwickelt editoriale Systeme und Journal-Strukturen, die diese Art der Content-Produktion ermöglichen, nachhaltig machen und konsistent halten. Kein Blog als Nachgedanke, sondern eine Content-Architektur, die von Anfang an für Langform-Storytelling, organische Suchsichtbarkeit und die Art von Thought Leadership konzipiert ist, die Architekten, Innenarchitekten und anspruchsvolle Käufer anzieht.</p>
          <p>Wir beraten auch zur Content-Strategie — welche Themen besetzt werden sollten, welche Formate für welche Zielgruppen funktionieren, und wie Inhalte so strukturiert werden, dass sie über die Zeit an Wert gewinnen.</p>
        </div>
        <div class="col-editorial-list">
          <div class="editorial-item">
            <span class="editorial-label">Journal-Systeme</span>
            <span class="editorial-text">Strukturierte editoriale Plattformen für Kollektionen, Neuigkeiten, Interviews und Langform-Inhalte</span>
          </div>
          <div class="editorial-item">
            <span class="editorial-label">Materialgeschichten</span>
            <span class="editorial-text">Eigene Seiten für Materialien, Oberflächen, Herstellungsprozesse und Beschaffungsnarrative</span>
          </div>
          <div class="editorial-item">
            <span class="editorial-label">Referenzprojekte</span>
            <span class="editorial-text">Case-Study-Strukturen für Installationen, Hotelprojekte und Wohnreferenzen</span>
          </div>
          <div class="editorial-item">
            <span class="editorial-label">Organische Sichtbarkeit</span>
            <span class="editorial-text">Content-Architektur, die Suchautorität in Möbel-, Interior- und Design-Kategorien aufbaut</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/work/the-grey" class="work-link">
            <div class="work-media">
              <img
                src="/work/thegrey-berlin/00-cover.jpg"
                alt="thegrey.berlin — Brand Identity & Website für ein Berliner Teppich- und Interior-Label"
                loading="lazy"
                class="img-bottom"
              />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey">
            <span>Projekt ansehen</span> <span class="arr">→</span>
          </a>
        </article>
        <article class="work-item">
          <a href="/work/jina-kim" class="work-link">
            <div class="work-media">
              <img
                src="/work/jina-kim/cover.jpg"
                alt="Ji-Na Kim — Editorial Brand Site"
                loading="lazy"
              />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim">
            <span>Projekt ansehen</span> <span class="arr">→</span>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- 9. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Für Suchmaschinen gebaut.<br />
          <em>Bereit für KI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Das Suchverhalten ändert sich. Die Art, wie Möbelkäufer, Innenarchitekten, Architekten und Handelseinkäufer Marken entdecken, hat sich verschoben — und verschiebt sich weiter.</p>
          <p>Zunehmend nutzen Fachleute KI-Systeme, um Kategorien zu recherchieren, Lieferanten zu vergleichen, Inspiration zu finden und Optionen zu bewerten, bevor sie Kontakt aufnehmen. Eine Möbelmarke, die nicht klar für maschinenlesbare Inhalte strukturiert ist, ist für diese Systeme unsichtbar — unabhängig davon, wie gut ihre Produkte sind.</p>
          <p>Greyform strukturiert Inhalte, Leistungsseiten, Case Studies und Journal-Beiträge so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, was eine Marke herstellt, für wen sie ist und warum sie relevant ist. Das ist kein technischer Nachgedanke — es ist ein grundlegender Teil der Gestaltung digitaler Systeme.</p>
          <p>Semantisches HTML, strukturierte Daten, klare Entity-Beziehungen, konsistente Terminologie und inhaltliche Tiefe werden von Tag eins jedes Projekts berücksichtigt — nicht am Ende als Optimierungsaufgabe hinzugefügt.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantische Struktur</span>
            <span class="pillar-value">Sauberes HTML, korrekte Überschriftenhierarchie, Entity-Klarheit</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Strukturierte Daten</span>
            <span class="pillar-value">Schema.org-Markup für Produkte, Leistungen, FAQs und Markenidentität</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Inhaltliche Tiefe</span>
            <span class="pillar-value">Langform-Seiten, die echte Fragen echter Zielgruppen beantworten</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">KI-Lesbarkeit</span>
            <span class="pillar-value">Inhalte strukturiert für ChatGPT, Gemini, Perplexity und Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>Wir beginnen mit einem fokussierten Briefing — Ihre Marke, Ihre Zielgruppen, Ihre Ziele. Keine langen Discovery-Phasen oder teure Strategiedokumente. Ein klares Gespräch, ein gemeinsames Verständnis, ein definierter Umfang.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>Wir gestalten das vollständige visuelle System — Typografie, Layout, Farbe, Bildbehandlung, Komponentenbibliothek — bevor wir eine Zeile Code schreiben. Sie reviewen, reagieren und wir verfeinern. In der Regel zwei Überarbeitungsrunden bis zur Freigabe.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Entwicklung</h3>
            <p>Wir bauen die Site mit derselben Sorgfalt wie das Design. Performance, semantisches HTML, SEO-Struktur und Content-System-Architektur werden als Kernleistungen behandelt, nicht als optionale Extras.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Übergabe</h3>
            <p>Wir übernehmen den technischen Launch — Domain-Konfiguration, Hosting-Setup, Analytics und Sitemap-Einreichung. Wir dokumentieren das Content-System klar und übergeben alles, damit Ihr Team von Tag eins eigenständig arbeiten kann.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. VERWANDTE LEISTUNGEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        {/* Zukünftiger Link: /interior-marken-websites */}
        <div class="related-item">
          <span class="related-label">Interior Brands</span>
          <p>Editoriale Websites und digitale Systeme für Interior-Marken und Labels. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        {/* Zukünftiger Link: /architekturbüro-websites */}
        <div class="related-item">
          <span class="related-label">Architekturbüros</span>
          <p>Projekt-Portfolios und Studio-Präsenzen für Architekturbüros. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        {/* Zukünftiger Link: /lifestyle-marken-websites */}
        <div class="related-item">
          <span class="related-label">Lifestyle Brands</span>
          <p>Editoriale Systeme für Lifestyle-Marken mit Haltung und Ästhetik. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        <div class="related-item">
          <a href="/" class="related-label related-link">Studio-Übersicht →</a>
          <p>Alle Leistungen, ausgewählte Arbeiten und Studio-Ansatz auf der Greyform-Hauptseite.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 12. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">11</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>

      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqs.map(f => ({
          "@type": "Question",
          "name": f.q,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": f.a
          }
        }))
      })} />
    </div>
  </section>

  <!-- 13. CTA -->
  <section class="section-cta">
    <div class="wrap">
      <div class="cta-inner">
        <div class="eyebrow-row">
          <span class="num">12</span>
          <span class="dash"></span>
          <span class="eyebrow">Projekt starten</span>
        </div>
        <h2>
          Lassen Sie uns über<br />
          <em>Ihr Projekt sprechen.</em>
        </h2>
        <p>Ob Sie eine neue Kollektion launchen, eine etablierte Möbelmarke neu positionieren oder einen stärkeren digitalen Auftritt aufbauen möchten — wir freuen uns auf das Gespräch. Wir antworten innerhalb von zwei Werktagen mit einer ehrlichen Einschätzung und einem klaren nächsten Schritt.</p>
        <a href="mailto:hello@greyform.studio" class="cta-btn">Gespräch beginnen →</a>
        <p class="cta-sub">Oder <a href="/#contact">nutzen Sie das Kontaktformular</a> auf unserer Hauptseite.</p>
      </div>
    </div>
  </section>

</BaseLayout>

