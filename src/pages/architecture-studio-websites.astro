---
import BaseLayout from "../layouts/BaseLayout.astro";

const lang = "de";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Digitale Auftritte für Architekturbüros",
  "provider": {
    "@type": "ProfessionalService",
    "name": "Studio Greyform",
    "url": "https://greyform.studio"
  },
  "description": "Greyform gestaltet Websites und digitale Systeme für Architekturbüros und Innenarchitekturbüros. Studio in Berlin, international tätig.",
  "areaServed": "Worldwide",
  "serviceType": ["Website Design", "Editorial Design", "Content-Systeme"],
  "audience": {
    "@type": "Audience",
    "audienceType": "Architekturbüros, Innenarchitekturbüros, Planungsbüros, Design-Studios"
  },
  "knowsAbout": ["Architekturbüro-Websites", "Projekt-Portfolios", "Studio-Präsenzen", "Innenarchitektur-Websites"]
};

const faqs = [
  {
    q: "Arbeiten Sie mit Architekturbüros und Innenarchitekturbüros?",
    a: "Ja — mit beiden. Und mit Büros die beides machen. Architekturbüros und Innenarchitekturbüros haben ähnliche digitale Anforderungen: Projekte als Herzstück, klare Kompetenz-Kommunikation, ein System das wächst. Der Unterschied liegt im Ton und in der Bildsprache — und den gestalten wir gemeinsam."
  },
  {
    q: "Wie präsentiert man Architekturprojekte auf einer Website richtig?",
    a: "Projekte brauchen mehr als Bilder. Sie brauchen Kontext: Aufgabenstellung, Ansatz, Material, Besonderheit. Greyform entwickelt Projektsysteme die beides ermöglichen — große atmosphärische Bilder und die inhaltliche Tiefe, die einen Wettbewerber von einem Auftraggeber überzeugt."
  },
  {
    q: "Wie lange dauert ein Projekt?",
    a: "Ein fokussiertes Projekt dauert in der Regel drei bis sechs Wochen von Briefing bis Launch. Der Zeitrahmen hängt vom Umfang des Portfolios und davon ab, ob ein vollständiges Projektsystem oder ein Team-Bereich integriert wird."
  },
  {
    q: "Können wir neue Projekte selbst hinzufügen?",
    a: "Ja — und das ist entscheidend. Architekturbüros gewinnen kontinuierlich neue Projekte. Das Content-System muss es ermöglichen, neue Arbeiten eigenständig zu ergänzen — ohne Entwickler, ohne Wartezeit."
  },
  {
    q: "Arbeiten Sie auch international?",
    a: "Ja. Greyform arbeitet international. Das Studio ist in Berlin ansässig und betreut Projekte auf Deutsch und Englisch. Wir haben mit Studios in ganz Europa zusammengearbeitet."
  },
  {
    q: "Können Sie bei SEO und KI-Sichtbarkeit helfen?",
    a: "Ja. Architekturbüros werden zunehmend über KI-Systeme entdeckt — von Bauherren, Entwicklern und Redakteuren die nach Planungspartnern suchen. Wir strukturieren Inhalte so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, was ein Büro macht und wofür es steht."
  }
];
---

<BaseLayout
  title="Websites für Architekturbüros & Innenarchitekturbüros — Greyform Studio Berlin"
  description="Greyform gestaltet Projekt-Portfolios und digitale Studio-Präsenzen für Architekturbüros und Innenarchitekturbüros. Berlin, international tätig."
  lang={lang}
>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- 1. HERO -->
  <header class="hero" id="top">
    <div class="wrap">
      <div class="hero-tag">
        <span class="dot"></span>
        <span>Digitale Auftritte · Architekturbüros</span>
      </div>
      <h1>
        <span>Websites für</span><br />
        <em>Architekturbüros.</em>
      </h1>
      <div class="hero-foot">
        <p class="hero-sub">Greyform gestaltet Projekt-Portfolios und digitale Studio-Präsenzen für Architekturbüros und Innenarchitekturbüros — präzise, eigenständig pflegbar, klar positioniert.</p>
        <div class="hero-meta">
          <div class="row">
            <span>Berlin</span>
            <span>Worldwide</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- 2. PROJEKTE ALS HERZSTÜCK -->
  <section class="section-why">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">01</span>
          <span class="dash"></span>
          <span class="eyebrow">Die Aufgabe</span>
        </div>
        <h2>
          Projekte die sprechen.<br />
          <em>Ein Studio das überzeugt.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Die Website eines Architekturbüros hat eine klare Aufgabe: potenzielle Auftraggeber überzeugen — bevor das erste Gespräch stattfindet.</p>
          <p>Das gilt für Architekturbüros genauso wie für Innenarchitekturbüros. Und für Büros die beides machen. Die digitale Präsenz ist oft der erste Eindruck — und der entscheidet, ob ein Bauherr, Investor oder Projektentwickler das Gespräch sucht oder weiterschaut.</p>
          <p>Projekte sind das Herzstück. Aber Projekte allein reichen nicht. Ein Architekturbüro muss digital kommunizieren: was es kann, wie es denkt, wofür es steht. Das ist eine Kommunikationsaufgabe, nicht nur eine Design-Aufgabe.</p>
          <p>Greyform entwickelt digitale Systeme für Architekturbüros, die beides leisten: Projekte in ihrer ganzen Qualität zeigen — und die Haltung des Studios dahinter klar machen. Kein generisches Portfolio. Ein überzeugendes Studio-Portrait.</p>
        </div>
        <div class="col-stat">
          <div class="stat-block">
            <div class="stat-item">
              <span class="stat-value">3–6</span>
              <span class="stat-label">Wochen von Briefing bis Launch</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">100%</span>
              <span class="stat-label">Neue Projekte eigenständig ergänzbar</span>
            </div>
            <div class="stat-item">
              <span class="stat-value">DE / EN</span>
              <span class="stat-label">Bilingual als Standard</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATEMENT 1 -->
  <section class="section-statement">
    <div class="wrap">
      <h2 class="statement-text">
        Ein Projekt ist mehr<br />
        als seine Bilder.<br />
        <em>Es ist eine Haltung.</em>
      </h2>
    </div>
  </section>

  <!-- 3. ARCHITEKTUR VS INNENARCHITEKTUR -->
  <section class="section-needs">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">02</span>
          <span class="dash"></span>
          <span class="eyebrow">Architektur & Innenarchitektur</span>
        </div>
        <h2>
          Zwei Disziplinen.<br />
          <em>Ähnliche digitale Anforderungen.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architekturbüros und Innenarchitekturbüros haben unterschiedliche Schwerpunkte — aber ähnliche digitale Bedürfnisse.</p>
          <p>Architekturbüros kommunizieren oft im B2B-Kontext: Bauherren, Projektentwickler, öffentliche Auftraggeber. Die Website muss Kompetenz, Erfahrung und Haltung klar vermitteln. Projekte brauchen Tiefe: Aufgabenstellung, Ansatz, Kontext, Ergebnis.</p>
          <p>Innenarchitekturbüros bewegen sich oft zwischen B2B und B2C. Die Bildsprache ist atmosphärischer, die Zielgruppen vielfältiger — Privatkunden, Hotelprojekte, Retail, Büroausstattung. Die Website muss beides können: überzeugen und verführen.</p>
          <p>Büros die beides machen, brauchen eine Struktur die beides zeigen kann — ohne Kompromisse in der Klarheit. Wir entwickeln Systeme, die das ermöglichen.</p>
        </div>
        <div class="col-credibility">
          <div class="credibility-list">
            <div class="cred-item">
              <span class="cred-label">Architekturbüros</span>
              <span class="cred-text">Kompetenz-Kommunikation, Projektiefe, Wettbewerbe, Awards, Team und Studio-Profil</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Innenarchitekturbüros</span>
              <span class="cred-text">Atmosphärische Bildsprache, Raumgefühl, Materialien, B2C- und B2B-Kommunikation</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Gemischte Büros</span>
              <span class="cred-text">Flexible Strukturen die Architektur und Innenarchitektur klar unterscheidbar aber kohärent zeigen</span>
            </div>
            <div class="cred-item">
              <span class="cred-label">Projektsysteme</span>
              <span class="cred-text">Eigenständig pflegbare Portfolios — neue Projekte in Minuten ergänzbar, ohne Entwickler</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. HÄUFIGE PROBLEME -->
  <section class="section-problems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">03</span>
          <span class="dash"></span>
          <span class="eyebrow">Häufige Probleme</span>
        </div>
        <h2>
          Was bei Architekturbüro-<br />
          <em>Websites schiefläuft.</em>
        </h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <span class="problem-num">i</span>
          <h3>Bilder ohne Kontext</h3>
          <p>Schöne Projektfotos — aber kein Text der erklärt was die Aufgabe war, wie das Büro gedacht hat und was das Projekt besonders macht. Potenzielle Auftraggeber sehen Ergebnisse, verstehen aber nicht die Kompetenz dahinter.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">ii</span>
          <h3>Veraltetes Portfolio</h3>
          <p>Websites die mit einem Entwickler aktualisiert werden müssen, bleiben schnell hinter dem tatsächlichen Stand zurück. Neue Projekte fehlen. Die Site zeigt nicht mehr, was das Büro heute kann.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iii</span>
          <h3>Kein klares Studio-Portrait</h3>
          <p>Viele Architekturbüros zeigen Projekte, aber kaum Studio. Wer sind die Menschen dahinter? Was ist die Haltung? Was unterscheidet dieses Büro? Diese Fragen bleiben unbeantwortet.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">iv</span>
          <h3>Schwache Auffindbarkeit</h3>
          <p>Architekturbüros die kaum über Google oder KI-Systeme gefunden werden — weil die Website keine semantische Struktur hat und die Projekte nicht als maschinenlesbare Inhalte aufgebaut sind.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">v</span>
          <h3>Keine internationale Reichweite</h3>
          <p>Büros mit internationalen Projekten und Ambitionen — aber einsprachigen Websites. Internationale Auftraggeber, Publikationen und Jurys bleiben außen vor.</p>
        </div>
        <div class="problem-item">
          <span class="problem-num">vi</span>
          <h3>Template-Portfolio</h3>
          <p>Generische Portfolio-Themes die jeden Auftritt gleich aussehen lassen. Das visuelle System kommuniziert nichts über die Haltung des Büros — und das ist eine verpasste Chance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. UNSER ANSATZ -->
  <section class="section-approach">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">04</span>
          <span class="dash"></span>
          <span class="eyebrow">Unser Ansatz</span>
        </div>
        <h2>
          Kein Portfolio-Template.<br />
          <em>Ein Studio-Portrait.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Jedes Greyform-Projekt beginnt mit der Frage: Was macht dieses Büro unverwechselbar?</p>
          <p>Nicht: Welches Template passt am besten? Sondern: Was ist die Haltung, die Bildsprache, die Art zu denken — und wie übersetzen wir das in ein digitales System, das genau das kommuniziert?</p>
          <p>Das Ergebnis ist eine Website die sich wie ein natürlicher Ausdruck des Studios anfühlt. Kein generisches Portfolio. Ein Auftritt der bereits vor dem ersten Gespräch Vertrauen schafft — und der nach dem Launch eigenständig mit dem Büro wächst.</p>
          <p class="internal-links">Referenzprojekte: <a href="/work/the-grey">thegrey.berlin — Brand Identity & Website</a> · <a href="/work/jina-kim">Ji-Na Kim — Editorial Brand Site</a></p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Ansatz</span>
            <span class="pillar-value">Studio-Portrait, nicht Projekt-Liste</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Tempo</span>
            <span class="pillar-value">Wochen, nicht Monate</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Ästhetik</span>
            <span class="pillar-value">Präzise · Architektonisch</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Sprachen</span>
            <span class="pillar-value">DE / EN · International</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. PROJEKTSYSTEME -->
  <section class="section-content-systems">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">05</span>
          <span class="dash"></span>
          <span class="eyebrow">Projektsysteme</span>
        </div>
        <h2>
          Neue Projekte.<br />
          <em>Eigenständig ergänzt.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architekturbüros gewinnen kontinuierlich neue Projekte. Das digitale System muss mithalten.</p>
          <p>Deshalb entwickeln wir flexible Projektsysteme — keine statischen Websites. Jedes Greyform-Projekt ist so strukturiert, dass Ihr Team neue Projekte eigenständig ergänzen, bestehende aktualisieren und das Portfolio kontinuierlich weiterentwickeln kann — ohne Entwickler, ohne Wartezeit.</p>
          <p>Das System ist auf die Bedürfnisse eines Planungsbüros ausgelegt: strukturierte Projekteinträge mit Bildern, Texten, Kategorien und Metadaten. Filterfunktionen nach Typus, Maßstab oder Jahr. Team-Seiten. Presse- und Awards-Bereich. Alles eigenständig, alles im Browser.</p>
        </div>
        <div class="col-features">
          <ul class="feature-list">
            <li>Projektverwaltung mit Bildern und Texten</li>
            <li>Kategorien nach Typus und Maßstab</li>
            <li>Team- und Studio-Seiten</li>
            <li>Presse- und Awards-Bereich</li>
            <li>Kein Entwickler für neue Projekte erforderlich</li>
            <li>Vollständige Dokumentation bei Übergabe</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. AUSGEWÄHLTE ARBEITEN -->
  <section class="section-work">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">06</span>
          <span class="dash"></span>
          <span class="eyebrow">Ausgewählte Arbeiten</span>
        </div>
        <h2>
          Aktuelle Projekte<br />
          <em>aus dem Studio.</em>
        </h2>
      </div>
      <div class="work-grid">
        <article class="work-item">
          <a href="/work/the-grey" class="work-link">
            <div class="work-media">
              <img src="/work/thegrey-berlin/00-cover.jpg" alt="thegrey.berlin — Brand Identity & Website" loading="lazy" class="img-bottom" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">thegrey.berlin</span>
            <span class="work-cat">Brand Identity · Website</span>
          </div>
          <a class="work-arrow" href="/work/the-grey"><span>Projekt ansehen</span> <span class="arr">→</span></a>
        </article>
        <article class="work-item">
          <a href="/work/jina-kim" class="work-link">
            <div class="work-media">
              <img src="/work/jina-kim/cover.jpg" alt="Ji-Na Kim — Editorial Brand Site" loading="lazy" />
            </div>
          </a>
          <div class="work-meta">
            <span class="work-title">Ji-Na Kim</span>
            <span class="work-cat">Editorial · Brand Site</span>
          </div>
          <a class="work-arrow" href="/work/jina-kim"><span>Projekt ansehen</span> <span class="arr">→</span></a>
        </article>
      </div>
    </div>
  </section>

  <!-- STATEMENT 2 -->
  <section class="section-statement-dark">
    <div class="wrap">
      <h2 class="statement-text-dark">
        Sichtbar für Menschen.<br />
        <em>Verständlich für KI.</em>
      </h2>
    </div>
  </section>

  <!-- 8. KI-SICHTBARKEIT -->
  <section class="section-ai">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">07</span>
          <span class="dash"></span>
          <span class="eyebrow">Suche & Sichtbarkeit</span>
        </div>
        <h2>
          Für Suchmaschinen gebaut.<br />
          <em>Bereit für KI.</em>
        </h2>
      </div>
      <div class="two-col">
        <div class="col-text">
          <p class="lead">Architekturbüros werden zunehmend über KI-Systeme entdeckt — von Bauherren, Entwicklern, Redakteuren und Jurys die nach Planungspartnern suchen.</p>
          <p>Eine Website ohne semantische Struktur und maschinenlesbare Inhalte ist für diese Systeme unsichtbar — unabhängig davon, wie gut die Projekte sind. KI-Systeme können nur empfehlen was sie verstehen.</p>
          <p>Greyform strukturiert Projektseiten, Studio-Texte, Awards und Presseberichte so, dass sowohl Suchmaschinen als auch KI-Systeme klar verstehen, was ein Büro macht, wo es tätig ist und wofür es steht.</p>
        </div>
        <div class="col-pillars">
          <div class="pillar">
            <span class="pillar-label">Semantische Struktur</span>
            <span class="pillar-value">Sauberes HTML, korrekte Hierarchie, Entity-Klarheit</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Strukturierte Daten</span>
            <span class="pillar-value">Schema.org-Markup für Studio, Projekte und Leistungen</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">Inhaltliche Tiefe</span>
            <span class="pillar-value">Projektbeschreibungen die Kompetenz und Haltung kommunizieren</span>
          </div>
          <div class="pillar">
            <span class="pillar-label">KI-Lesbarkeit</span>
            <span class="pillar-value">Inhalte strukturiert für ChatGPT, Gemini, Perplexity und Google AI Overviews</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. PROZESS -->
  <section class="section-process">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">08</span>
          <span class="dash"></span>
          <span class="eyebrow">Prozess</span>
        </div>
        <h2>
          Wie ein Projekt<br />
          <em>Form annimmt.</em>
        </h2>
      </div>
      <div class="process-steps">
        <div class="process-step">
          <span class="step-num">01</span>
          <div class="step-content">
            <h3>Briefing & Discovery</h3>
            <p>Wir beginnen mit einem fokussierten Briefing — Ihr Studio, Ihre Projekte, Ihre Zielgruppen. Ein klares Gespräch, ein gemeinsames Verständnis, ein definierter Umfang.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">02</span>
          <div class="step-content">
            <h3>Design</h3>
            <p>Wir gestalten das vollständige visuelle System — Typografie, Layout, Bildbehandlung, Projektseitenstruktur — bevor wir eine Zeile Code schreiben. In der Regel zwei Überarbeitungsrunden bis zur Freigabe.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">03</span>
          <div class="step-content">
            <h3>Entwicklung</h3>
            <p>Wir bauen die Site mit derselben Sorgfalt wie das Design. Performance, semantisches HTML, SEO-Struktur und Projektsystem-Architektur als Kernleistungen.</p>
          </div>
        </div>
        <div class="process-step">
          <span class="step-num">04</span>
          <div class="step-content">
            <h3>Launch & Übergabe</h3>
            <p>Wir übernehmen den technischen Launch und dokumentieren das Projektsystem klar — damit Ihr Team von Tag eins eigenständig neue Projekte ergänzen kann.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. VERWANDTE LEISTUNGEN -->
  <section class="section-related">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">09</span>
          <span class="dash"></span>
          <span class="eyebrow">Verwandt</span>
        </div>
        <h2>
          Weitere Branchen,<br />
          <em>mit denen wir arbeiten.</em>
        </h2>
      </div>
      <div class="related-grid">
        <div class="related-item">
          <a href="/furniture-brand-websites" class="related-label related-link">Möbelmarken →</a>
          <p>Digitale Auftritte für Möbelhersteller, Designmarken und Produktunternehmen.</p>
        </div>
        <div class="related-item">
          <a href="/interior-brand-websites" class="related-label related-link">Interior-Marken →</a>
          <p>Websites und Content-Systeme für Interior-, Licht-, Textil- und Home-Brands.</p>
        </div>
        <div class="related-item">
          <span class="related-label">Lifestyle Brands</span>
          <p>Editoriale Systeme für Lifestyle-Marken mit Haltung und Ästhetik. <span class="related-soon">— Seite in Kürze</span></p>
        </div>
        <div class="related-item">
          <a href="/" class="related-label related-link">Studio-Übersicht →</a>
          <p>Alle Leistungen, ausgewählte Arbeiten und Studio-Ansatz auf der Greyform-Hauptseite.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="section-faq">
    <div class="wrap">
      <div class="section-head">
        <div class="eyebrow-row">
          <span class="num">10</span>
          <span class="dash"></span>
          <span class="eyebrow">FAQ</span>
        </div>
        <h2>
          Häufig gestellte<br />
          <em>Fragen.</em>
        </h2>
      </div>
      <div class="faq-list">
        {faqs.map((item) => (
          <details class="faq-item">
            <summary class="faq-question">
              <span>{item.q}</span>
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
      <script type="application/ld+json" set:html={JSON.stringify({
