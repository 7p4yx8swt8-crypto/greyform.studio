---
import "../styles/global.css";
import type { Lang } from "../i18n/ui";
import { defaultLang } from "../i18n/ui";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "Studio Greyform — Digital experiences for design-driven brands",
  description = "Studio Greyform — Digital studio for interior, architecture and lifestyle brands. Editorial websites, visual systems. Berlin.",
  lang = defaultLang,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Studio Greyform" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
  </head>
<body>
    <Header lang={lang} />
    <slot />
    <Footer lang={lang} />
  </body>
</html>