---
import "../styles/global.css";
import type { Lang } from "../i18n/ui";
import { defaultLang } from "../i18n/ui";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = "Studio Greyform — Digital experiences for design-driven brands",
  description = "Studio Greyform ist ein digitales Studio für Interior-, Architektur- und Lifestyle-Marken in Berlin. Editoriale Websites, visuelle Systeme und digitale Markenpräsenzen.",
  lang = defaultLang,
} = Astro.props;

const site = "https://greyform.studio";
const currentPath = Astro.url.pathname;

// Canonical URL
const canonicalURL = new URL(currentPath, site).href;

// hreflang
const dePath = currentPath.startsWith("/en/")
  ? currentPath.replace(/^\/en/, "") || "/"
  : currentPath;
const enPath = currentPath.startsWith("/en/")
  ? currentPath
  : "/en" + (currentPath === "/" ? "/" : currentPath);

const deURL = new URL(dePath, site).href;
const enURL = new URL(enPath, site).href;

// Schema.org JSON-LD – nur auf Startseite ausgeben
const isHome = currentPath === "/" || currentPath === "/en/";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Studio Greyform",
  "url": "https://greyform.studio",
  "logo": "https://greyform.studio/favicon.svg",
  "image": "https://greyform.studio/og-image.png",
  "description": "Digitales Studio für Interior-, Architektur- und Lifestyle-Marken. Editoriale Websites, visuelle Systeme und digitale Markenpräsenzen.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Gardeschützenweg 18",
    "addressLocality": "Berlin",
    "postalCode": "12203",
    "addressCountry": "DE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 52.4345,
    "longitude": 13.3135
  },
  "telephone": "+49-178-1308965",
  "email": "hello@greyform.studio",
  "founder": {
    "@type": "Person",
    "name": "Patrik Salewski"
  },
  "foundingDate": "2026",
  "areaServed": {
    "@type": "City",
    "name": "Berlin"
  },
  "serviceType": [
    "Webdesign",
    "Brand Identity",
    "Editorial Design",
    "Digital Strategy"
  ],
  "sameAs": []
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Studio Greyform" />
    <meta name="google-site-verification" content="yZwzZz6BzI3MqcnFkr5kpAXOAzmrx70Dr-E3wttPmj4" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="de" href={deURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={deURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://greyform.studio/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Schema.org JSON-LD -->
    {isHome && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <title>{title}</title>
  </head>
  <body>
    <Header lang={lang} />
    <slot />
    <Footer lang={lang} />
  </body>
</html>
